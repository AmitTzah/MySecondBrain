<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:MySecondBrain.UI.Converters"
                    xmlns:mdxam="clr-namespace:MdXaml.SyntaxHigh;assembly=MdXaml.SyntaxHigh">

    <converters:RelativeTimeConverter x:Key="ThemeRelativeTimeConverter"/>
    <converters:FlowDirectionConverter x:Key="ThemeFlowDirectionConverter"/>

    <!-- Helper converter: returns "You" for User role, else "Assistant" / persona name -->
    <converters:BoolToVisibilityConverter x:Key="ThemeBoolToVisibility"/>

    <!-- Template for User messages (shows "You" label, right-aligned) -->
    <DataTemplate x:Key="ClassicUserTemplate">
        <StackPanel Margin="0,0,0,20" FlowDirection="RightToLeft">
            <TextBlock Text="You"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                       Margin="0,0,0,2"/>
            <Border Padding="12,8" CornerRadius="8,8,2,8" BorderThickness="1"
                    BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                    Background="{DynamicResource AccentFillColorDefaultBrush}">
                <mdxam:MarkdownScrollViewer Markdown="{Binding Content}"
                                         MarkdownStyleName="Sasabune"
                                         FlowDirection="{Binding Content, Converter={StaticResource ThemeFlowDirectionConverter}}"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Background="Transparent"/>
            </Border>
            <TextBlock FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,2,0,0" HorizontalAlignment="Right">
                <TextBlock.Text>
                    <MultiBinding Converter="{StaticResource ThemeRelativeTimeConverter}">
                        <Binding Path="CreatedAt"/>
                        <Binding Path="DataContext.TimeRefreshToken" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </StackPanel>
    </DataTemplate>

    <!-- Template for Assistant messages (shows persona name, left-aligned) -->
    <DataTemplate x:Key="ClassicAssistantTemplate">
        <StackPanel Margin="0,0,0,20">
            <TextBlock FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.ActivePersona.DisplayName, FallbackValue='Assistant'}"
                       Margin="0,0,0,2"/>
            <Border Padding="12,8" CornerRadius="2,8,8,8" BorderThickness="1"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    Background="{DynamicResource ApplicationBackgroundBrush}">
                <mdxam:MarkdownScrollViewer Markdown="{Binding Content}"
                                         MarkdownStyleName="Sasabune"
                                         FlowDirection="{Binding Content, Converter={StaticResource ThemeFlowDirectionConverter}}"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Background="Transparent"/>
            </Border>
            <TextBlock FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,2,0,0">
                <TextBlock.Text>
                    <MultiBinding Converter="{StaticResource ThemeRelativeTimeConverter}">
                        <Binding Path="CreatedAt"/>
                        <Binding Path="DataContext.TimeRefreshToken" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </StackPanel>
    </DataTemplate>

    <!-- Compact User Template -->
    <DataTemplate x:Key="CompactUserTemplate">
        <StackPanel Margin="0,0,0,8" FlowDirection="RightToLeft">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                         Fill="{DynamicResource AccentFillColorDefaultBrush}"/>
                <mdxam:MarkdownScrollViewer Markdown="{Binding Content}"
                                         MarkdownStyleName="Sasabune"
                                         FlowDirection="{Binding Content, Converter={StaticResource ThemeFlowDirectionConverter}}"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Background="Transparent"/>
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <!-- Compact Assistant Template -->
    <DataTemplate x:Key="CompactAssistantTemplate">
        <StackPanel Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                         Fill="{DynamicResource AccentFillColorDefaultBrush}"/>
                <mdxam:MarkdownScrollViewer Markdown="{Binding Content}"
                                         MarkdownStyleName="Sasabune"
                                         FlowDirection="{Binding Content, Converter={StaticResource ThemeFlowDirectionConverter}}"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Background="Transparent"/>
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <!-- Bubble User Template -->
    <DataTemplate x:Key="BubbleUserTemplate">
        <Grid Margin="0,0,0,12">
            <Border Padding="12,8" CornerRadius="12,12,2,12" BorderThickness="1"
                    BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                    Background="{DynamicResource AccentFillColorDefaultBrush}" MaxWidth="400"
                    HorizontalAlignment="Right" Opacity="0.9">
                <StackPanel FlowDirection="RightToLeft">
                    <mdxam:MarkdownScrollViewer Markdown="{Binding Content}"
                                             MarkdownStyleName="Sasabune"
                                             FlowDirection="{Binding Content, Converter={StaticResource ThemeFlowDirectionConverter}}"
                                             VerticalScrollBarVisibility="Hidden"
                                             HorizontalScrollBarVisibility="Disabled"
                                             Background="Transparent"/>
                    <TextBlock FontSize="9"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Left" Margin="0,4,0,0">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource ThemeRelativeTimeConverter}">
                                <Binding Path="CreatedAt"/>
                                <Binding Path="DataContext.TimeRefreshToken" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>

    <!-- Bubble Assistant Template -->
    <DataTemplate x:Key="BubbleAssistantTemplate">
        <Grid Margin="0,0,0,12">
            <Border Padding="12,8" CornerRadius="2,12,12,12" BorderThickness="1"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    Background="{DynamicResource ApplicationBackgroundBrush}" MaxWidth="400"
                    HorizontalAlignment="Left" Opacity="0.9">
                <StackPanel>
                    <mdxam:MarkdownScrollViewer Markdown="{Binding Content}"
                                             MarkdownStyleName="Sasabune"
                                             FlowDirection="{Binding Content, Converter={StaticResource ThemeFlowDirectionConverter}}"
                                             VerticalScrollBarVisibility="Hidden"
                                             HorizontalScrollBarVisibility="Disabled"
                                             Background="Transparent"/>
                    <TextBlock FontSize="9"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right" Margin="0,4,0,0">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource ThemeRelativeTimeConverter}">
                                <Binding Path="CreatedAt"/>
                                <Binding Path="DataContext.TimeRefreshToken" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>

    <!-- Classic Message Template (shared fallback) -->
    <DataTemplate x:Key="ClassicMessageTemplate">
        <StackPanel Margin="0,0,0,20">
            <TextBlock FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Message" Margin="0,0,0,2"/>
            <mdxam:MarkdownScrollViewer Markdown="{Binding Content}"
                                     MarkdownStyleName="Sasabune"
                                     FlowDirection="{Binding Content, Converter={StaticResource ThemeFlowDirectionConverter}}"
                                     VerticalScrollBarVisibility="Hidden"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Background="Transparent"/>
        </StackPanel>
    </DataTemplate>

    <!-- Compact Message Template (shared fallback) -->
    <DataTemplate x:Key="CompactMessageTemplate">
        <StackPanel Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                         Fill="{DynamicResource AccentFillColorDefaultBrush}"/>
                <mdxam:MarkdownScrollViewer Markdown="{Binding Content}"
                                         MarkdownStyleName="Sasabune"
                                         FlowDirection="{Binding Content, Converter={StaticResource ThemeFlowDirectionConverter}}"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Background="Transparent"/>
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <!-- Bubble Message Template (shared fallback) -->
    <DataTemplate x:Key="BubbleMessageTemplate">
        <Grid Margin="0,0,0,12">
            <Border Padding="12,8" CornerRadius="12" BorderThickness="1"
                    BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                    Background="{DynamicResource ApplicationBackgroundBrush}" MaxWidth="400"
                    HorizontalAlignment="Left" Opacity="0.85">
                <StackPanel>
                    <mdxam:MarkdownScrollViewer Markdown="{Binding Content}"
                                             MarkdownStyleName="Sasabune"
                                             FlowDirection="{Binding Content, Converter={StaticResource ThemeFlowDirectionConverter}}"
                                             VerticalScrollBarVisibility="Hidden"
                                             HorizontalScrollBarVisibility="Disabled"
                                             Background="Transparent"/>
                    <TextBlock FontSize="9"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right" Margin="0,4,0,0">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource ThemeRelativeTimeConverter}">
                                <Binding Path="CreatedAt"/>
                                <Binding Path="DataContext.TimeRefreshToken" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>

</ResourceDictionary>
