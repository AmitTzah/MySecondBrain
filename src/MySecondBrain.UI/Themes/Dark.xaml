<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ===== Backgrounds ===== -->
    <SolidColorBrush x:Key="AppBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SidebarBackground" Color="#252526"/>
    <SolidColorBrush x:Key="ContentBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#252526"/>
    <SolidColorBrush x:Key="TabBarBackground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="TabActiveBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TabInactiveBackground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="HeaderBackground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="InputBackground" Color="#2D2D2D"/>

    <!-- ===== Foregrounds ===== -->
    <SolidColorBrush x:Key="AppForeground" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SidebarForeground" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ContentForeground" Color="#D4D4D4"/>
    <SolidColorBrush x:Key="PanelForeground" Color="#CCCCCC"/>

    <!-- ===== Accent ===== -->
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentForeground" Color="#FFFFFF"/>

    <!-- ===== Borders & Misc ===== -->
    <SolidColorBrush x:Key="BorderBrush" Color="#3E3E3E"/>
    <SolidColorBrush x:Key="SubtleBrush" Color="#555555"/>
    <SolidColorBrush x:Key="ScrollBarBrush" Color="#424242"/>
    <SolidColorBrush x:Key="GridSplitterBrush" Color="#3E3E3E"/>

    <!-- ===== Semantic ===== -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>

    <!-- ===== Navigation ===== -->
    <SolidColorBrush x:Key="NavActiveBackground" Color="#2563EB"/>
    <SolidColorBrush x:Key="NavInactiveForeground" Color="#999999"/>

    <!-- ===== Typography ===== -->
    <FontFamily x:Key="FontFamily">Segoe UI</FontFamily>
    <sys:Double x:Key="FontSize">14</sys:Double>

</ResourceDictionary>
