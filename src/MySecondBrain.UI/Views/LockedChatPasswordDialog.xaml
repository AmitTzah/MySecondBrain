<Window x:Class="MySecondBrain.UI.Views.LockedChatPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MySecondBrain.UI.Views"
        mc:Ignorable="d"
        Title="Lock Chat" Height="240" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        AutomationProperties.AutomationId="LockedChatDialog">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                   Text="{Binding DialogTitle}" Margin="0,0,0,12"/>

        <!-- Password input -->
        <TextBlock Grid.Row="1" FontSize="12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Password:" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="2" x:Name="PasswordInput"
                     Height="32" FontSize="14"
                     Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                     AutomationProperties.AutomationId="LockPasswordInput"/>

        <!-- Confirm Password (only shown for Lock mode) -->
        <StackPanel Grid.Row="3" Visibility="{Binding IsLockMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Confirm password:" Margin="0,8,0,4"/>
            <PasswordBox x:Name="ConfirmPasswordInput"
                         Height="32" FontSize="14"
                         Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                         BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                         AutomationProperties.AutomationId="LockConfirmPasswordInput"/>
        </StackPanel>

        <!-- Warning text -->
        <TextBlock Grid.Row="4" FontSize="11"
                   Foreground="{DynamicResource SystemFillColorCautionBrush}"
                   TextWrapping="Wrap" Margin="0,8,0,0">
            If you lose this password, chat content cannot be recovered.
        </TextBlock>

        <!-- Error text -->
        <TextBlock Grid.Row="5" FontSize="11"
                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                   Text="{Binding ErrorMessage}"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                   Margin="0,4,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Cancel" Width="80" Height="30"
                    Background="Transparent"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    IsCancel="True"
                    Margin="0,0,8,0"
                    AutomationProperties.AutomationId="LockCancelBtn"/>
            <Button Content="{Binding ActionButtonText}" Width="100" Height="30"
                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                    Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                    BorderThickness="0"
                    IsDefault="True"
                    Click="OnConfirmClick"
                    AutomationProperties.AutomationId="LockConfirmBtn"/>
        </StackPanel>
    </Grid>
</Window>
