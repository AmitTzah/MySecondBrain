<UserControl x:Class="MySecondBrain.UI.Views.ModelComparisonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}"
             AutomationProperties.AutomationId="ModelComparisonView">
    <Grid AutomationProperties.AutomationId="ModelComparisonView">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <TextBlock Text="⚖️ Model Comparison" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource ContentForeground}"/>
        </Border>

        <!-- Row 1: Setup Phase (Persona checklist + prompt input) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Persona Checklist -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="Select Models" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource SidebarForeground}"
                               Margin="0,0,0,8"/>
                    <CheckBox Content="GPT-4o" Foreground="{DynamicResource SidebarForeground}"
                              FontSize="12" Margin="0,0,0,4"/>
                    <CheckBox Content="Claude 3.5 Sonnet" Foreground="{DynamicResource SidebarForeground}"
                              FontSize="12" Margin="0,0,0,4"/>
                    <CheckBox Content="Gemini 2.0 Flash" Foreground="{DynamicResource SidebarForeground}"
                              FontSize="12" Margin="0,0,0,4"/>
                    <CheckBox Content="DeepSeek V3" Foreground="{DynamicResource SidebarForeground}"
                              FontSize="12" Margin="0,0,0,4"/>
                    <CheckBox Content="MiMo" Foreground="{DynamicResource SidebarForeground}"
                              FontSize="12" Margin="0,0,0,4"/>
                    <CheckBox Content="Mistral Large" Foreground="{DynamicResource SidebarForeground}"
                              FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Right: Prompt Input + Results Placeholder -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Prompt Input -->
                <Border Grid.Row="0" Background="{DynamicResource InputBackground}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="Enter your prompt to compare model responses:"
                                   FontSize="12" Foreground="{DynamicResource SubtleBrush}"
                                   Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource ContentBackground}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="12,8" Height="80">
                            <TextBlock Text="Type a prompt..."
                                       Foreground="{DynamicResource SubtleBrush}"
                                       FontSize="13" VerticalAlignment="Top"/>
                        </Border>
                        <Button Content="Run Comparison" HorizontalAlignment="Right"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="{DynamicResource AccentForeground}"
                                BorderThickness="0"
                                Padding="16,6" FontSize="12" FontWeight="SemiBold"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Results Phase: Side-by-Side Panels -->
                <UniformGrid Grid.Row="1" Columns="2">
                    <Border Background="{DynamicResource PanelBackground}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Margin="8" CornerRadius="6" Padding="12">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Model A" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PanelForeground}"/>
                            <TextBlock Text="Select models and run comparison"
                                       FontSize="11"
                                       Foreground="{DynamicResource SubtleBrush}"
                                       Margin="0,4,0,0" TextWrapping="Wrap"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource PanelBackground}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Margin="8" CornerRadius="6" Padding="12">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Model B" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PanelForeground}"/>
                            <TextBlock Text="Select models and run comparison"
                                       FontSize="11"
                                       Foreground="{DynamicResource SubtleBrush}"
                                       Margin="0,4,0,0" TextWrapping="Wrap"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
