<UserControl x:Class="MySecondBrain.UI.Views.MediaLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Filter Bar -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel>
                <TextBlock Text="Media Library" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource ContentForeground}"
                           VerticalAlignment="Center" Margin="0,0,0,10"/>

                <WrapPanel>
                    <!-- Search -->
                    <Border Background="{DynamicResource InputBackground}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="8,4" Margin="0,0,8,0"
                            MinWidth="200">
                        <TextBlock Text="🔍 Search by filename..."
                                   FontSize="12" Foreground="{DynamicResource SubtleBrush}"/>
                    </Border>

                    <!-- Type filter -->
                    <Border Background="{DynamicResource InputBackground}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                        <TextBlock Text="All Types ▾" FontSize="12"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                    </Border>

                    <!-- Source chat filter -->
                    <Border Background="{DynamicResource InputBackground}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                        <TextBlock Text="All Chats ▾" FontSize="12"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                    </Border>

                    <!-- Sort -->
                    <Border Background="{DynamicResource InputBackground}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="8,4">
                        <TextBlock Text="Newest ▾" FontSize="12"
                                   Foreground="{DynamicResource SubtleBrush}"/>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Row 1: Media Grid -->
        <Border Grid.Row="1" Background="{DynamicResource ContentBackground}">
            <TextBlock Text="No media files yet"
                       Foreground="{DynamicResource SubtleBrush}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
