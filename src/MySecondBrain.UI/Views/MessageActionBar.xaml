<UserControl x:Class="MySecondBrain.UI.Views.MessageActionBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="ActionBarRoot">
    <Border Background="{DynamicResource ContentBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="4,2"
            Opacity="0.0">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=ActionBarRoot}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.0" To="1.0" Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                        <DataTrigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1.0" To="0.0" Duration="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.ExitActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <StackPanel Orientation="Horizontal">
            <!-- Star / Favorited -->
            <Button x:Name="StarBtn" Content="☆" FontSize="14"
                    ToolTip="Favorite" Padding="4,2"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource SubtleBrush}"
                    AutomationProperties.AutomationId="FavoriteBtn"/>

            <!-- Copy Markdown -->
            <Button x:Name="CopyMdBtn" Content="📋" FontSize="12"
                    ToolTip="Copy Markdown" Padding="4,2"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource SubtleBrush}"
                    AutomationProperties.AutomationId="CopyMDBtn"/>

            <!-- Copy Rich -->
            <Button x:Name="CopyRichBtn" Content="📄" FontSize="12"
                    ToolTip="Copy Rich Text" Padding="4,2"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource SubtleBrush}"
                    AutomationProperties.AutomationId="CopyRichBtn"/>

            <!-- Edit -->
            <Button x:Name="EditBtn" Content="✏️" FontSize="12"
                    ToolTip="Edit" Padding="4,2"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource SubtleBrush}"
                    AutomationProperties.AutomationId="EditMessageBtn"/>

            <!-- Delete -->
            <Button x:Name="DeleteBtn" Content="🗑️" FontSize="12"
                    ToolTip="Delete" Padding="4,2"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource SubtleBrush}"
                    AutomationProperties.AutomationId="DeleteMessageBtn"/>

            <!-- Regenerate (assistant only) -->
            <Button x:Name="RegenerateBtn" Content="🔄" FontSize="12"
                    ToolTip="Regenerate" Padding="4,2"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource SubtleBrush}"
                    AutomationProperties.AutomationId="RegenerateBtn"/>
        </StackPanel>
    </Border>
</UserControl>
