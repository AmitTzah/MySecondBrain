<UserControl x:Class="MySecondBrain.UI.Views.Onboarding.OnboardingStep1View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:MySecondBrain.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="580"
             AutomationProperties.AutomationId="OnboardingStep1View">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Choose Your Assistant" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="A Persona defines how the AI behaves. Pick one and customize it to your style."
                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,16"/>

            <!-- 3 Starter Persona Cards -->
            <ItemsControl ItemsSource="{Binding StarterPersonas}" Margin="0,0,0,12">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:StarterPersonaCard}">
                        <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="12,10" Margin="0,0,0,6"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.SelectPersonaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{Binding PromptPreview}" FontSize="10"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Customization Panel (visible when persona selected or creating from scratch) -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Customize Persona" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding PersonaDisplayName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12"
                             Background="{DynamicResource ApplicationBackgroundBrush}"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                             BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                             BorderThickness="1" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding PersonaSystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="60" MaxHeight="120"
                             Background="{DynamicResource ApplicationBackgroundBrush}"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                             BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                             BorderThickness="1" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding ChatModeOptions}"
                              SelectedItem="{Binding PersonaChatMode}"
                              FontSize="12" Margin="0,0,0,8"
                              Background="{DynamicResource ApplicationBackgroundBrush}"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <Button Content="Save Persona" FontSize="12" FontWeight="SemiBold"
                            Padding="16,6" HorizontalAlignment="Left"
                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                            Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                            BorderThickness="0"
                            Command="{Binding SavePersonaCommand}"
                            AutomationProperties.AutomationId="WizardSavePersona"/>
                </StackPanel>
            </Border>

            <!-- Create from Scratch link -->
            <TextBlock Text="Create from Scratch" FontSize="11"
                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                       Cursor="Hand" TextDecorations="Underline"
                       AutomationProperties.AutomationId="WizardCreatePersona">
                <TextBlock.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding CreateFromScratchCommand}"/>
                </TextBlock.InputBindings>
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
