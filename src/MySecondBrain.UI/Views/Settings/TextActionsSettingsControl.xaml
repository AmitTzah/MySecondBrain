<UserControl x:Class="MySecondBrain.UI.Views.Settings.TextActionsSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MySecondBrain.UI.ViewModels">
    <UserControl.Resources><ResourceDictionary><Style x:Key="IconButtonStyle" TargetType="Button"><Setter Property="Width" Value="28"/><Setter Property="Height" Value="24"/><Setter Property="FontSize" Value="11"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Foreground" Value="{DynamicResource SubtleBrush}"/><Setter Property="Margin" Value="2,0"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.7"/></Trigger></Style.Triggers></Style><Style x:Key="AccentButtonStyle" TargetType="Button"><Setter Property="OverridesDefaultStyle" Value="True"/><Setter Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="11"/><Setter Property="Padding" Value="12,5"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.7"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style><Style x:Key="SecondaryButtonStyle" TargetType="Button"><Setter Property="OverridesDefaultStyle" Value="True"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Foreground" Value="{DynamicResource ContentForeground}"/><Setter Property="FontSize" Value="11"/><Setter Property="Padding" Value="12,5"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.7"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style></ResourceDictionary></UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="⚡ Text Actions" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource ContentForeground}" Margin="16,16,16,4"/>
        <TextBlock Grid.Row="1" Text="Manage text transformation actions that can be triggered via hotkey or command bar. Each action defines a capture scope, apply mode, and optional model configuration."
                   FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                   TextWrapping="Wrap" Margin="16,0,16,12"/>

        <Grid Grid.Row="2" Margin="16,0,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Background="{DynamicResource CardBackground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="12,10,12,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Actions" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ContentForeground}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="+ New Text Action" Padding="8,4"
                                Command="{Binding AddTextActionCommand}" Style="{StaticResource AccentButtonStyle}"
                                AutomationProperties.AutomationId="AddTextActionButton"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" Margin="10,0,10,8" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <ItemsControl ItemsSource="{Binding TextActions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:TextActionDisplayItem">
                                        <Border Padding="10,8" Margin="0,0,0,2" Background="{DynamicResource CardBackground}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource ContentForeground}"/>
                                                        <Border Padding="4,1" CornerRadius="3" Margin="6,0,0,0"
                                                                Background="{DynamicResource AccentBrush}" Opacity="0.7" BorderThickness="0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="Built-in" FontSize="8" Foreground="White"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding TruncatedSystemPrompt}" FontSize="10"
                                                               Foreground="{DynamicResource SubtleBrush}" TextWrapping="Wrap" MaxHeight="32"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding CaptureScopeBadges}" FontSize="10"
                                                                   Foreground="{DynamicResource SubtleBrush}" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding ApplyModeLabel}" FontSize="10"
                                                                   Foreground="{DynamicResource SubtleBrush}" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Hotkey}" FontSize="10"
                                                                   Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="📋" Style="{StaticResource IconButtonStyle}" ToolTip="Duplicate"
                                                            Command="{Binding DataContext.DuplicateTextActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="✏️" Style="{StaticResource IconButtonStyle}" ToolTip="Edit"
                                                            Command="{Binding DataContext.EditTextActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="🗑️" Style="{StaticResource IconButtonStyle}" ToolTip="Delete"
                                                            Command="{Binding DataContext.DeleteTextActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TextActions.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                            <TextBlock Text="No text actions yet. Click '+ New Text Action' to create one."
                                       FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                                       TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TextActions.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Margin="0" HorizontalAlignment="Center"
                          Background="Transparent" IsEnabled="False"/>

            <Border Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Background="{DynamicResource CardBackground}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditingTextAction}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,12,14,12">
                        <TextBlock Text="{Binding EditingTextAction.DisplayName, TargetNullValue='New Text Action'}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ContentForeground}" Margin="0,0,0,12"/>

                        <TextBlock Text="Display Name" FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding TextActionDisplayNameValue, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="11" Margin="0,0,0,8"/>

                        <TextBlock Text="System Prompt" FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding TextActionSystemPromptValue, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="11" Margin="0,0,0,8" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="60" MaxHeight="120" VerticalScrollBarVisibility="Auto"/>

                        <TextBlock Text="Capture Scope" FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,3"/>
                        <CheckBox IsChecked="{Binding CaptureSelection}" Content="Selection" FontSize="11"
                                  Foreground="{DynamicResource ContentForeground}" Margin="0,0,0,2"/>
                        <CheckBox IsChecked="{Binding CaptureFocusedElement}" Content="Focused Element" FontSize="11"
                                  Foreground="{DynamicResource ContentForeground}" Margin="0,0,0,2"/>
                        <CheckBox IsChecked="{Binding CaptureSurroundingContext}" Content="Surrounding Context" FontSize="11"
                                  Foreground="{DynamicResource ContentForeground}" Margin="0,0,0,2"/>
                        <CheckBox IsChecked="{Binding CaptureFullDocument}" Content="Full Document" FontSize="11"
                                  Foreground="{DynamicResource ContentForeground}" Margin="0,0,0,2"/>
                        <CheckBox IsChecked="{Binding CaptureScreenshot}" Content="Screenshot" FontSize="11"
                                  Foreground="{DynamicResource ContentForeground}" Margin="0,0,0,8"/>

                        <TextBlock Text="Apply Mode" FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding ApplyModeOptions}" SelectedItem="{Binding SelectedApplyMode}"
                                  FontSize="11" Margin="0,0,0,8"/>

                        <TextBlock Text="Hotkey" FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,3"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding TextActionAssignedHotkey}"
                                     FontSize="11" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="⌨️" Width="28" Height="24" Margin="4,0,0,0"
                                    Command="{Binding AssignTextActionHotkeyCommand}"
                                    ToolTip="Record a hotkey for this text action"/>
                        </Grid>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="10"
                                       Foreground="{DynamicResource SubtleBrush}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Cancel" Margin="0,0,8,0"
                                    Command="{Binding CancelTextActionEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button Grid.Column="2" Content="Save" Padding="12,5"
                                    Command="{Binding SaveTextActionCommand}"
                                    Style="{StaticResource AccentButtonStyle}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Background="{DynamicResource CardBackground}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditingTextAction}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Select a text action or click '+ New Text Action' to create one."
                           FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" Margin="20"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
