<UserControl x:Class="MySecondBrain.UI.Views.Settings.AppearanceSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MySecondBrain.UI.Converters">
    <UserControl.Resources><ResourceDictionary><Style x:Key="IconButtonStyle" TargetType="Button"><Setter Property="Width" Value="28"/><Setter Property="Height" Value="24"/><Setter Property="FontSize" Value="11"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Foreground" Value="{DynamicResource SubtleBrush}"/><Setter Property="Margin" Value="2,0"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.7"/></Trigger></Style.Triggers></Style><Style x:Key="AccentButtonStyle" TargetType="Button"><Setter Property="OverridesDefaultStyle" Value="True"/><Setter Property="Background" Value="{DynamicResource AccentBrush}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="11"/><Setter Property="Padding" Value="12,5"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.7"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style><Style x:Key="SecondaryButtonStyle" TargetType="Button"><Setter Property="OverridesDefaultStyle" Value="True"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Foreground" Value="{DynamicResource ContentForeground}"/><Setter Property="FontSize" Value="11"/><Setter Property="Padding" Value="12,5"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.7"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
            <converters:EnumMatchConverter x:Key="EnumMatchConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="🎨 Appearance" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource ContentForeground}" Margin="16,16,16,4"/>
        <TextBlock Grid.Row="1" Text="Customize the visual theme, chat layout, and font settings. Changes take effect immediately."
                   FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                   TextWrapping="Wrap" Margin="16,0,16,12"/>
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="16,0,16,8">
            <StackPanel>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                        Background="{DynamicResource CardBackground}" Margin="0,0,0,12">
                    <StackPanel Margin="14,12,14,12">
                        <TextBlock Text="Theme" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ContentForeground}" Margin="0,0,0,4"/>
                        <TextBlock Text="Switch between Dark and Light mode."
                                   FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="🌙 Dark" GroupName="AppTheme"
                                         IsChecked="{Binding AppTheme, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Dark}"
                                         FontSize="11" Foreground="{DynamicResource ContentForeground}" Margin="0,0,20,0"/>
                            <RadioButton Content="☀️ Light" GroupName="AppTheme"
                                         IsChecked="{Binding AppTheme, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Light}"
                                         FontSize="11" Foreground="{DynamicResource ContentForeground}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                        Background="{DynamicResource CardBackground}" Margin="0,0,0,12">
                    <StackPanel Margin="14,12,14,12">
                        <TextBlock Text="Chat Theme" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ContentForeground}" Margin="0,0,0,4"/>
                        <TextBlock Text="Choose the layout style for chat messages."
                                   FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <ComboBox ItemsSource="{Binding ChatThemeOptions}" SelectedItem="{Binding ChatTheme}"
                                  FontSize="11" Width="200" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                        Background="{DynamicResource CardBackground}" Margin="0,0,0,12">
                    <StackPanel Margin="14,12,14,12">
                        <TextBlock Text="Font Settings" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ContentForeground}" Margin="0,0,0,4"/>
                        <TextBlock Text="Adjust the font family, size, and weight used throughout the application."
                                   FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <TextBlock Text="Font Family" FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding FontFamilyOptions}" SelectedItem="{Binding FontFamily}"
                                  FontSize="11" Width="220" HorizontalAlignment="Left" Margin="0,0,0,10" IsEditable="True"/>
                        <TextBlock Text="Font Size" FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Slider Minimum="10" Maximum="24" SmallChange="1" LargeChange="2"
                                    Value="{Binding FontSize}" Width="180"
                                    TickFrequency="1" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding FontSize, StringFormat={}{0:F0}px}" Width="40"
                                       TextAlignment="Center" VerticalAlignment="Center"
                                       FontSize="11" Foreground="{DynamicResource ContentForeground}"/>
                        </StackPanel>
                        <TextBlock Text="Font Weight" FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding FontWeightOptions}" SelectedItem="{Binding FontWeight}"
                                  FontSize="11" Width="120" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Background="{DynamicResource ContentBackground}" Padding="12,8">
                            <TextBlock Text="{Binding FontPreviewText}" FontFamily="{Binding FontFamily}"
                                       FontSize="{Binding FontSize}" FontWeight="{Binding FontWeight}"
                                       Foreground="{DynamicResource ContentForeground}" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
