<UserControl x:Class="MySecondBrain.UI.Views.Settings.PricingSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="💰 Pricing" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource ContentForeground}" Margin="16,16,16,4"/>
        <TextBlock Grid.Row="1" Text="Set monthly budget limits and configure cost alert thresholds."
                   FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                   TextWrapping="Wrap" Margin="16,0,16,12"/>
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="16,0,16,8">
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                    Background="{DynamicResource CardBackground}" MaxWidth="500" HorizontalAlignment="Left">
                <StackPanel Margin="14,12,14,12">
                    <TextBlock Text="Budget Settings" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource ContentForeground}" Margin="0,0,0,4"/>
                    <TextBlock Text="Set a monthly budget limit and warning threshold to track API usage costs."
                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <TextBlock Text="Monthly Budget Limit ($)" FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding MonthlyBudgetLimit, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11" Width="150" HorizontalAlignment="Left" Margin="0,0,0,10"
                             ToolTip="Leave empty for no limit"/>
                    <TextBlock Text="Warning Threshold (%)" FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Slider Minimum="50" Maximum="100" SmallChange="5" LargeChange="10"
                                Value="{Binding WarningThreshold}" Width="180"
                                TickFrequency="5" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="{Binding WarningThreshold, StringFormat={}{0}%}" Width="40"
                                   TextAlignment="Center" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{DynamicResource ContentForeground}"/>
                    </StackPanel>
                    <CheckBox IsChecked="{Binding BlockApiOnLimit}" Content="Block API calls when limit reached" FontSize="11"
                              Foreground="{DynamicResource ContentForeground}"
                              ToolTip="When enabled, API calls to paid providers will be blocked once the monthly budget limit is exceeded."/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
