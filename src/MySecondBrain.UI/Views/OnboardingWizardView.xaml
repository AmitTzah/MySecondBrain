<UserControl x:Class="MySecondBrain.UI.Views.OnboardingWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MySecondBrain.UI.ViewModels"
             xmlns:models="clr-namespace:MySecondBrain.Core.Models;assembly=MySecondBrain.Core"
             xmlns:viewsOnboarding="clr-namespace:MySecondBrain.UI.Views.Onboarding"
             Background="{DynamicResource ApplicationBackgroundBrush}"
             AutomationProperties.AutomationId="OnboardingWizardView">
    <UserControl.Resources>
        <ResourceDictionary>
            <!-- Converters -->
            <vm:StepDotConverter x:Key="StepDotConverter"/>
            <vm:InvertedVisibilityConverter x:Key="InvertedVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid AutomationProperties.AutomationId="OnboardingWizardViewRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Main content Grid -->
        <Grid Grid.Row="0" AutomationProperties.AutomationId="OnboardingWizardGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================================================================
             Row 0: Header
             ================================================================ -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🧠 MySecondBrain" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Onboarding" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ================================================================
             Row 1: Step Dots (Steps 0-3)
             ================================================================ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,24,0,12"
                    Visibility="{Binding IsStepScreen, Converter={StaticResource BoolToVisibility}}">
            <!-- Step 1 Dot -->
            <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                <Border Width="24" Height="24" CornerRadius="12"
                        Background="{Binding Step1Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=bg}"
                        BorderBrush="{Binding Step1Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=bg}"
                        BorderThickness="2" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Step1Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=icon}"
                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{Binding Step1Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=fg}"/>
                </Border>
                <TextBlock Text="API Keys" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Connector line -->
            <Border Width="32" Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" VerticalAlignment="Top" Margin="0,12,0,0"/>

            <!-- Step 2 Dot -->
            <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                <Border Width="24" Height="24" CornerRadius="12"
                        Background="{Binding Step2Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=bg}"
                        BorderBrush="{Binding Step2Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=bg}"
                        BorderThickness="2" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Step2Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=icon}"
                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{Binding Step2Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=fg}"/>
                </Border>
                <TextBlock Text="Persona" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Connector line -->
            <Border Width="32" Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" VerticalAlignment="Top" Margin="0,12,0,0"/>

            <!-- Step 3 Dot -->
            <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                <Border Width="24" Height="24" CornerRadius="12"
                        Background="{Binding Step3Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=bg}"
                        BorderBrush="{Binding Step3Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=bg}"
                        BorderThickness="2" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Step3Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=icon}"
                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{Binding Step3Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=fg}"/>
                </Border>
                <TextBlock Text="Wiki" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Connector line -->
            <Border Width="32" Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" VerticalAlignment="Top" Margin="0,12,0,0"/>

            <!-- Step 4 Dot -->
            <StackPanel Orientation="Vertical">
                <Border Width="24" Height="24" CornerRadius="12"
                        Background="{Binding Step4Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=bg}"
                        BorderBrush="{Binding Step4Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=bg}"
                        BorderThickness="2" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Step4Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=icon}"
                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{Binding Step4Completed, Converter={StaticResource StepDotConverter}, ConverterParameter=fg}"/>
                </Border>
                <TextBlock Text="Hotkeys" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- ================================================================
             Row 2: Content Card
             ================================================================ -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                CornerRadius="8" MaxWidth="580"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinHeight="340" Margin="20,0">
            <Grid Margin="32,28">

                <!-- ============================================================
                     Screen -1: Welcome
                     ============================================================ -->
                <StackPanel Visibility="{Binding IsWelcomeScreen, Converter={StaticResource BoolToVisibility}}"
                            VerticalAlignment="Center">
                    <TextBlock Text="🧠" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Welcome to MySecondBrain" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Your unified AI hub — any model, any provider, your own keys"
                               FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,24"/>
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Feature Card 1 -->
                        <Border Grid.Column="0" Background="{DynamicResource ApplicationBackgroundBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="10" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="🔄" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Three-Tier AI" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                           Margin="0,4,0,2"/>
                                <TextBlock Text="Hotkey rewrites, Command Bar, and full Studio" FontSize="9"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Feature Card 2 -->
                        <Border Grid.Column="1" Background="{DynamicResource ApplicationBackgroundBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="10" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="🔑" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Bring Your Own Keys" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                           Margin="0,4,0,2"/>
                                <TextBlock Text="Use any AI provider. No platform lock-in." FontSize="9"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Feature Card 3 -->
                        <Border Grid.Column="2" Background="{DynamicResource ApplicationBackgroundBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="10" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="📝" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Personal Wiki" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                           Margin="0,4,0,2"/>
                                <TextBlock Text="AI conversations into permanent .md notes" FontSize="9"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Button Content="Get Started" FontSize="14" FontWeight="SemiBold"
                            Padding="32,10"
                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                            Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                            BorderThickness="0" HorizontalAlignment="Center"
                            Command="{Binding GetStartedCommand}"
                            AutomationProperties.AutomationId="WizardGetStarted"/>
                </StackPanel>

                <!-- ============================================================
                     Screen 0: API Keys
                     ============================================================ -->
                <viewsOnboarding:OnboardingStep0View>
                    <viewsOnboarding:OnboardingStep0View.Style>
                        <Style TargetType="viewsOnboarding:OnboardingStep0View">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsOnboarding:OnboardingStep0View.Style>
                </viewsOnboarding:OnboardingStep0View>

                <!-- ============================================================
                     Screen 1: Persona
                     ============================================================ -->
                <viewsOnboarding:OnboardingStep1View>
                    <viewsOnboarding:OnboardingStep1View.Style>
                        <Style TargetType="viewsOnboarding:OnboardingStep1View">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsOnboarding:OnboardingStep1View.Style>
                </viewsOnboarding:OnboardingStep1View>

                <!-- ============================================================
                     Screen 2: Wiki
                     ============================================================ -->
                <viewsOnboarding:OnboardingStep2View>
                    <viewsOnboarding:OnboardingStep2View.Style>
                        <Style TargetType="viewsOnboarding:OnboardingStep2View">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsOnboarding:OnboardingStep2View.Style>
                </viewsOnboarding:OnboardingStep2View>

                <!-- ============================================================
                     Screen 3: Hotkeys
                     ============================================================ -->
                <viewsOnboarding:OnboardingStep3View>
                    <viewsOnboarding:OnboardingStep3View.Style>
                        <Style TargetType="viewsOnboarding:OnboardingStep3View">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsOnboarding:OnboardingStep3View.Style>
                </viewsOnboarding:OnboardingStep3View>

                <!-- ============================================================
                     Screen 4: Finish
                     ============================================================ -->
                <viewsOnboarding:OnboardingStep4View>
                    <viewsOnboarding:OnboardingStep4View.Style>
                        <Style TargetType="viewsOnboarding:OnboardingStep4View">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFinishScreen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsOnboarding:OnboardingStep4View.Style>
                </viewsOnboarding:OnboardingStep4View>
            </Grid>
        </Border>

        <!-- ================================================================
             Row 3: Navigation Bar
             ================================================================ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,12,0,24">
            <Button Content="Back"
                    IsEnabled="{Binding CanGoBack}"
                    Visibility="{Binding IsWelcomeScreen, Converter={StaticResource InvertedVisibilityConverter}}"
                    Command="{Binding GoBackCommand}"
                    Background="Transparent"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Padding="24,8" FontSize="12" Margin="0,0,8,0"
                    AutomationProperties.AutomationId="WizardBack"/>
            <Button Content="Skip"
                    Visibility="{Binding CanSkip, Converter={StaticResource BoolToVisibility}}"
                    Command="{Binding SkipCommand}"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Padding="24,8" FontSize="12" Margin="0,0,8,0"
                    AutomationProperties.AutomationId="WizardSkip"/>
            <Button Content="{Binding NextButtonText}"
                    Visibility="{Binding IsStepScreen, Converter={StaticResource BoolToVisibility}}"
                    Command="{Binding GoNextCommand}"
                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                    Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                    BorderThickness="0"
                    Padding="24,8" FontSize="12" FontWeight="SemiBold"
                    AutomationProperties.AutomationId="WizardNext"/>
        </StackPanel>
        </Grid>

        <!-- ================================================================
             Hotkey Recording Overlay
             ================================================================ -->
        <Border Background="#80000000"
                Visibility="{Binding IsRecordingHotkey, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="100">
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="32,24"
                    Width="320" Height="160"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Press new key combination..."
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource AccentFillColorDefaultBrush}" BorderThickness="2"
                            CornerRadius="4" Padding="12,8"
                            x:Name="HotkeyComboDisplay">
                        <TextBlock Text="{Binding RecordingHotkeyCombo}" FontSize="16"
                                   FontFamily="Consolas" Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Press Escape to cancel"
                               FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
