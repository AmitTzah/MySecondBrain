<UserControl x:Class="MySecondBrain.UI.Views.OnboardingWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Step Indicator (4 dots) -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,40,0,24">
            <Ellipse Width="12" Height="12" Fill="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
            <Ellipse Width="12" Height="12" Fill="{DynamicResource BorderBrush}" Margin="0,0,8,0"/>
            <Ellipse Width="12" Height="12" Fill="{DynamicResource BorderBrush}" Margin="0,0,8,0"/>
            <Ellipse Width="12" Height="12" Fill="{DynamicResource BorderBrush}"/>
        </StackPanel>

        <!-- Row 1: Content Card -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" MaxWidth="560" MaxHeight="400"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="40">
                <TextBlock Text="🚀" FontSize="48" HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Welcome to MySecondBrain"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource ContentForeground}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Your local-first AI workspace for chat, wiki, media, and more."
                           FontSize="14"
                           Foreground="{DynamicResource SubtleBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,0,0,24"/>
                <TextBlock Text="Let's set up your workspace in 4 quick steps:"
                           FontSize="13"
                           Foreground="{DynamicResource ContentForeground}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <StackPanel HorizontalAlignment="Left" Margin="0,0,0,24">
                    <TextBlock Text="1. Add your API keys" FontSize="12"
                               Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="2. Configure your first persona" FontSize="12"
                               Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="3. Choose your wiki folder" FontSize="12"
                               Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="4. Set your preferences" FontSize="12"
                               Foreground="{DynamicResource SubtleBrush}"/>
                </StackPanel>
                <Button Content="Get Started"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource AccentForeground}"
                        BorderThickness="0"
                        Padding="24,10" FontSize="14" FontWeight="SemiBold"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Row 2: Bottom Navigation -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,16,0,32">
            <Button Content="Back" IsEnabled="False"
                    Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Foreground="{DynamicResource SubtleBrush}"
                    Padding="20,6" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="Skip"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource SubtleBrush}"
                    Padding="20,6" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="Next"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource AccentForeground}"
                    BorderThickness="0"
                    Padding="20,6" FontSize="12" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</UserControl>
