<UserControl x:Class="MySecondBrain.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MySecondBrain.UI.ViewModels"
             xmlns:models="clr-namespace:MySecondBrain.Core.Models;assembly=MySecondBrain.Core"
             xmlns:converters="clr-namespace:MySecondBrain.UI.Converters"
             Background="{DynamicResource ContentBackground}"
             AutomationProperties.AutomationId="SettingsView">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:EnumMatchConverter x:Key="EnumMatchConverter"/>
            <!-- Reusable style for icon buttons (Copy, Edit, Delete, Duplicate) with very subtle hover/press feedback -->
            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="28"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{DynamicResource SubtleBrush}"/>
                <Setter Property="Margin" Value="2,0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.85"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Opacity" Value="0.7"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Style for accent (primary action) buttons — suppresses default WPF chrome hover effects -->
            <Style x:Key="AccentButtonStyle" TargetType="Button">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Padding" Value="12,5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Style for secondary (Cancel) buttons — suppresses default WPF chrome hover effects -->
            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="{DynamicResource ContentForeground}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Padding" Value="12,5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Sidebar item template -->
            <DataTemplate x:Key="SidebarItemTemplate" DataType="vm:SettingsCategoryItem">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Icon}" FontSize="11" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Label}" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DataTemplate>

            <!-- Model Configuration list item template -->
            <DataTemplate x:Key="ModelConfigListItemTemplate" DataType="vm:ModelConfigurationDisplayItem">
                <Border Padding="10,8" Margin="0,0,0,2"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ContentForeground}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding ProviderLabel}" FontSize="10"
                                           Foreground="{DynamicResource SubtleBrush}"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding ModelIdentifier}" FontSize="10"
                                           Foreground="{DynamicResource SubtleBrush}"/>
                            </StackPanel>
                            <TextBlock FontSize="10"
                                       Foreground="{DynamicResource SubtleBrush}">
                                <Run Text="Temp:"/>
                                <Run Text="{Binding Temperature, StringFormat={}{0:F1}}"/>
                                <Run Text="• Context:"/>
                                <Run Text="{Binding MaxContextWindow}"/>
                                <Run Text="• Overflow:"/>
                                <Run Text="{Binding ContextOverflowStrategy}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="📋" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Duplicate"
                                    Command="{Binding DataContext.DuplicateModelConfigCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                            <Button Content="✏️" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Edit"
                                    Command="{Binding DataContext.EditModelConfigCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                            <Button Content="🗑️" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Delete"
                                    Command="{Binding DataContext.DeleteModelConfigCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- Persona list item template -->
            <DataTemplate x:Key="PersonaListItemTemplate" DataType="vm:PersonaDisplayItem">
                <Border Padding="10,8" Margin="0,0,0,2"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ContentForeground}"/>
                                <Border Padding="4,1" CornerRadius="3" Margin="6,0,0,0"
                                        Background="{DynamicResource AccentBrush}" Opacity="0.7"
                                        BorderThickness="0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="Built-in" FontSize="8" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding DefaultModelConfigName}" FontSize="10"
                                           Foreground="{DynamicResource SubtleBrush}"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding DefaultChatMode}" FontSize="10"
                                           Foreground="{DynamicResource SubtleBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="✏️" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Edit"
                                    Command="{Binding DataContext.EditPersonaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                            <Button Content="🗑️" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Delete"
                                    Command="{Binding DataContext.DeletePersonaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- API Key list item template -->
            <DataTemplate x:Key="ApiKeyListItemTemplate" DataType="vm:ApiKeyDisplayItem">
                <Border Padding="10,8" Margin="0,0,0,2"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Valid/Invalid indicator -->
                        <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsValid}" Value="False">
                                            <Setter Property="Background" Value="#FF5252"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!-- Display name + masked value -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ContentForeground}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding ProviderLabel}" FontSize="10"
                                           Foreground="{DynamicResource SubtleBrush}"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding MaskedValue}" FontSize="10"
                                           Foreground="{DynamicResource SubtleBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button ToolTip="Copy API key to clipboard"
                                    Command="{Binding DataContext.CopyKeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                        <Setter Property="Content" Value="📋"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCopied}" Value="True">
                                                <Setter Property="Content" Value="✅"/>
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="✏️" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Edit"
                                    Command="{Binding DataContext.EditApiKeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                            <Button Content="🗑️" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Delete API key"
                                    Command="{Binding DataContext.DeleteApiKeyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Column 0: Settings Category Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Settings" FontSize="13" FontWeight="Bold"
                           Foreground="{DynamicResource SidebarForeground}"
                           Margin="12,10,12,6" Padding="0,0,0,6"/>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding CategoryItems}"
                         SelectedValue="{Binding SelectedSettingsCategory}"
                         SelectedValuePath="Category"
                         ItemTemplate="{StaticResource SidebarItemTemplate}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource SidebarForeground}"
                         FontSize="12"/>

                <TextBlock Grid.Row="2" Margin="12,8,12,12">
                    <Hyperlink Foreground="{DynamicResource AccentBrush}" FontSize="11"
                               TextDecorations="Underline">
                        🔄 Re-run Onboarding Wizard
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Column 1: Content Area -->
        <Border Grid.Column="1" Background="{DynamicResource ContentBackground}">
            <Grid>
                <!-- Providers Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Providers">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="🔑 API Keys" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Manage your LLM provider API keys. Keys are encrypted using Windows DPAPI and tied to your user account."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <!-- Main content: key list + form -->
                    <Grid Grid.Row="2" Margin="16,0,16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="380"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Existing API keys list -->
                        <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackground}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- List header -->
                                <Grid Grid.Row="0" Margin="12,10,12,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Saved Keys" FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="+ Add API Key"
                                            Padding="8,4"
                                            Command="{Binding AddApiKeyCommand}"
                                            Style="{StaticResource AccentButtonStyle}"
                                            AutomationProperties.AutomationId="AddApiKeyButton"/>
                                </Grid>

                                <!-- Key list -->
                                <ScrollViewer Grid.Row="1" Margin="10,0,10,8"
                                              VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <!-- Key items -->
                                        <ItemsControl ItemsSource="{Binding ApiKeys}"
                                                      ItemTemplate="{StaticResource ApiKeyListItemTemplate}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ApiKeys.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                        </ItemsControl>

                                        <!-- Empty state -->
                                        <TextBlock Text="No API keys configured yet. Click '+ Add API Key' to add one."
                                                   FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                                                   TextWrapping="Wrap" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Margin="20">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ApiKeys.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Separator -->
                        <GridSplitter Grid.Column="1" Width="4" Margin="0"
                                      HorizontalAlignment="Center"
                                      Background="Transparent"
                                      IsEnabled="False"/>

                        <!-- Right: Add/Edit form -->
                        <Border Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackground}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditingKey}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="{Binding FormTitle}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,14"
                                               AutomationProperties.AutomationId="ApiKeyFormTitle"/>

                                    <!-- Provider dropdown -->
                                    <TextBlock Text="Provider" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding AllProviderTypes}"
                                              SelectedItem="{Binding SelectedProviderType}"
                                              FontSize="11" Margin="0,0,0,10"
                                              AutomationProperties.AutomationId="ProviderTypeCombo"/>

                                    <!-- Display Name -->
                                    <TextBlock Text="Display Name (optional)" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding DisplayNameInputValue, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="11" Margin="0,0,0,10"
                                             AutomationProperties.AutomationId="DisplayNameInput"/>

                                    <!-- API Key input -->
                                    <TextBlock Text="API Key" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               Margin="0,0,0,3"/>
                                    <PasswordBox x:Name="ApiKeyPasswordBox"
                                                 FontSize="11" Margin="0,0,0,10"
                                                 AutomationProperties.AutomationId="ApiKeyInput"/>

                                    <!-- OpenAI-Compatible fields -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOpenAiCompatibleSelected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <TextBlock Text="Custom Provider Name" FontSize="11"
                                                   Foreground="{DynamicResource SubtleBrush}"
                                                   Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding CustomProviderNameValue, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="11" Margin="0,0,0,10"
                                                 AutomationProperties.AutomationId="CustomProviderNameInput"/>

                                        <TextBlock Text="Custom Endpoint URL" FontSize="11"
                                                   Foreground="{DynamicResource SubtleBrush}"
                                                   Margin="0,0,0,3"/>
                                        <TextBox Text="{Binding CustomEndpointUrlValue, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="11" Margin="0,0,0,10"
                                                 AutomationProperties.AutomationId="CustomEndpointUrlInput"/>
                                    </StackPanel>

                                    <!-- Combined action row: Test Key + Result + Cancel + Save -->
                                    <Grid Margin="0,4,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Content="Test Key"
                                                Padding="12,5"
                                                Command="{Binding TestApiKeyCommand}"
                                                AutomationProperties.AutomationId="TestKeyButton">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Setter Property="IsEnabled" Value="True"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                                            <Setter Property="Opacity" Value="0.6"/>
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Test result indicator -->
                                        <Grid Grid.Column="1" Margin="10,0,0,0"
                                              VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Success checkmark (only shown on success) -->
                                            <TextBlock Grid.Column="0" Text="✅" FontSize="14">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTestSuccess}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- Result message — always visible when there's content -->
                                            <TextBlock Grid.Column="1" Text="{Binding TestResultMessage}"
                                                       FontSize="10" Margin="4,0,0,0"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource SubtleBrush}"/>
                                            <!-- Testing... indicator -->
                                            <TextBlock Grid.Column="1" Text="Testing..." FontSize="10"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubtleBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>

                                        <!-- Cancel button -->
                                        <Button Grid.Column="2" Content="Cancel"
                                                Margin="0,0,8,0"
                                                Command="{Binding CancelEditCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"/>

                                        <!-- Save button -->
                                        <Button Grid.Column="3" Content="Save API Key"
                                                Padding="12,5"
                                                Command="{Binding SaveApiKeyCommand}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                AutomationProperties.AutomationId="SaveApiKeyButton"/>
                                    </Grid>

                                    <!-- Status message below the action row -->
                                    <TextBlock Text="{Binding StatusMessage}"
                                               FontSize="10" Margin="0,0,0,0"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Form placeholder when not editing -->
                        <Border Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackground}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditingKey}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Select an API key or click '+ Add API Key' to manage keys."
                                       FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       TextWrapping="Wrap" Margin="20"/>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Profiles Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Profiles">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="👤 Profiles" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Manage model configurations and personas. Model configurations define the engine (provider, model, temperature). Personas define the behavior (system prompt, default model config, chat mode)."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <!-- Main content: two sections -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <StackPanel>
                            <!-- ============================================================ -->
                            <!-- Model Configurations Section -->
                            <!-- ============================================================ -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Section header -->
                                    <Grid Grid.Row="0" Margin="12,10,12,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Model Configurations" FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ContentForeground}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="+ New Model Configuration"
                                                Padding="8,4"
                                                Command="{Binding AddModelConfigCommand}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                AutomationProperties.AutomationId="AddModelConfigButton"/>
                                    </Grid>

                                    <!-- Model config list or form -->
                                    <Grid Grid.Row="1" Margin="10,0,10,8">
                                        <!-- When NOT editing: show the list -->
                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditingModelConfig}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>

                                            <ItemsControl ItemsSource="{Binding ModelConfigurations}"
                                                          ItemTemplate="{StaticResource ModelConfigListItemTemplate}">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ModelConfigurations.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>
                                            </ItemsControl>

                                            <TextBlock Text="No model configurations yet. Click '+ New Model Configuration' to create one."
                                                       FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                                                       TextWrapping="Wrap" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Margin="20">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ModelConfigurations.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>

                                        <!-- When editing: show the form -->
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="6"
                                                Background="{DynamicResource CardBackground}"
                                                Padding="12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditingModelConfig}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <StackPanel>
                                                <TextBlock Text="{Binding EditingModelConfig.DisplayName, TargetNullValue='New Model Configuration'}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ContentForeground}"
                                                           Margin="0,0,0,12"/>

                                                <!-- Display Name -->
                                                <TextBlock Text="Display Name" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <TextBox Text="{Binding EditingModelConfig.DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Margin="0,0,0,8"/>

                                                <!-- Provider -->
                                                <TextBlock Text="Provider" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <ComboBox ItemsSource="{Binding AvailableApiKeys}"
                                                          SelectedItem="{Binding SelectedModelConfigApiKey}"
                                                          DisplayMemberPath="DisplayName"
                                                          FontSize="11" Margin="0,0,0,8"/>

                                                <!-- Model Identifier + Fetch -->
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Model Identifier" FontSize="11"
                                                                   Foreground="{DynamicResource SubtleBrush}"
                                                                   Margin="0,0,0,3"/>
                                                        <ComboBox ItemsSource="{Binding AvailableModels}"
                                                                  Text="{Binding EditingModelConfig.ModelIdentifier, UpdateSourceTrigger=PropertyChanged}"
                                                                  IsEditable="True"
                                                                  FontSize="11"
                                                                  AutomationProperties.AutomationId="ModelIdentifierCombo"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Fetch" Width="70"
                                                             FontSize="10" Margin="6,18,0,0"
                                                             Command="{Binding FetchModelsCommand}"
                                                             VerticalAlignment="Bottom"
                                                             Height="22"
                                                             AutomationProperties.AutomationId="FetchModelsButton">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                                                <Setter Property="IsEnabled" Value="True"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsFetchingModels}" Value="True">
                                                                        <Setter Property="IsEnabled" Value="False"/>
                                                                        <Setter Property="Content" Value="Fetching..."/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>

                                               <!-- Fetch error message -->
                                               <TextBlock Text="{Binding FetchModelsErrorMessage}"
                                                          FontSize="10" Foreground="#FF5252"
                                                          TextWrapping="Wrap" Margin="0,0,0,8">
                                                   <TextBlock.Style>
                                                       <Style TargetType="TextBlock">
                                                           <Style.Triggers>
                                                               <Trigger Property="Text" Value="">
                                                                   <Setter Property="Visibility" Value="Collapsed"/>
                                                               </Trigger>
                                                           </Style.Triggers>
                                                       </Style>
                                                   </TextBlock.Style>
                                               </TextBlock>

                                               <!-- Temperature Slider -->
                                                <TextBlock Text="Temperature" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Slider Minimum="0" Maximum="2" SmallChange="0.1" LargeChange="0.2"
                                                            Value="{Binding EditingModelConfig.Temperature}" Width="180"
                                                            TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                                                    <TextBlock Text="{Binding EditingModelConfig.Temperature, StringFormat={}{0:F1}}"
                                                               Width="30" TextAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="11" Foreground="{DynamicResource ContentForeground}"/>
                                                </StackPanel>

                                                <!-- Max Output Tokens -->
                                                <TextBlock Text="Max Output Tokens" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <TextBox Text="{Binding EditingModelConfig.MaxOutputTokens, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Margin="0,0,0,8"/>

                                                <!-- Max Context Window -->
                                                <TextBlock Text="Max Context Window" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <TextBox Text="{Binding EditingModelConfig.MaxContextWindow, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Margin="0,0,0,8"/>

                                                <!-- Thinking Enabled -->
                                                <CheckBox Content="Thinking Enabled"
                                                          IsChecked="{Binding EditingModelConfig.ThinkingEnabled}"
                                                          FontSize="11" Margin="0,0,0,8"
                                                          Foreground="{DynamicResource ContentForeground}"/>

                                                <!-- Pricing fields -->
                                                <TextBlock Text="Input Price (per 1K tokens, $)" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <TextBox Text="{Binding EditingModelConfig.PricingInputPer1K, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Margin="0,0,0,8"/>

                                                <TextBlock Text="Output Price (per 1K tokens, $)" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <TextBox Text="{Binding EditingModelConfig.PricingOutputPer1K, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Margin="0,0,0,8"/>

                                                <TextBlock Text="Cache Hit Price (per 1K tokens, $)" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <TextBox Text="{Binding EditingModelConfig.PricingCacheHitPer1K, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Margin="0,0,0,8"/>

                                                <TextBlock Text="Cache Miss Price (per 1K tokens, $)" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <TextBox Text="{Binding EditingModelConfig.PricingCacheMissPer1K, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Margin="0,0,0,8"/>

                                                <!-- Context Overflow Strategy -->
                                                <TextBlock Text="Context Overflow Strategy" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <ComboBox ItemsSource="{Binding ContextOverflowStrategyOptions}"
                                                          SelectedItem="{Binding EditingModelConfig.ContextOverflowStrategy}"
                                                          FontSize="11" Margin="0,0,0,8"/>

                                                <!-- Save / Cancel buttons -->
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource SubtleBrush}"
                                                               VerticalAlignment="Center"/>

                                                    <Button Grid.Column="1" Content="Cancel"
                                                            Margin="0,0,8,0"
                                                            Command="{Binding CancelModelConfigEditCommand}"
                                                            Style="{StaticResource SecondaryButtonStyle}"/>

                                                    <Button Grid.Column="2" Content="Save"
                                                            Padding="12,5"
                                                            Command="{Binding SaveModelConfigCommand}"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            AutomationProperties.AutomationId="SaveModelConfigButton"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- ============================================================ -->
                            <!-- Personas Section -->
                            <!-- ============================================================ -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Section header -->
                                    <Grid Grid.Row="0" Margin="12,10,12,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Personas" FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ContentForeground}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="+ New Persona"
                                                Padding="8,4"
                                                Command="{Binding AddPersonaCommand}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                AutomationProperties.AutomationId="AddPersonaButton"/>
                                    </Grid>

                                    <!-- Persona list or form -->
                                    <Grid Grid.Row="1" Margin="10,0,10,8">
                                        <!-- When NOT editing: show the list -->
                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditingPersona}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>

                                            <ItemsControl ItemsSource="{Binding Personas}"
                                                          ItemTemplate="{StaticResource PersonaListItemTemplate}">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Personas.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>
                                            </ItemsControl>

                                            <TextBlock Text="No personas yet. Click '+ New Persona' to create one."
                                                       FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                                                       TextWrapping="Wrap" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Margin="20">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Personas.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>

                                        <!-- When editing: show the form -->
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="6"
                                                Background="{DynamicResource CardBackground}"
                                                Padding="12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditingPersona}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <StackPanel>
                                                <TextBlock Text="{Binding EditingPersona.DisplayName, TargetNullValue='New Persona'}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ContentForeground}"
                                                           Margin="0,0,0,12"/>

                                                <!-- Display Name -->
                                                <TextBlock Text="Display Name" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <TextBox Text="{Binding EditingPersona.DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Margin="0,0,0,8"
                                                         AutomationProperties.AutomationId="PersonaDisplayNameInput"/>

                                                <!-- System Prompt -->
                                                <TextBlock Text="System Prompt" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <TextBox Text="{Binding EditingPersona.SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11" Margin="0,0,0,4"
                                                         AcceptsReturn="True" TextWrapping="Wrap"
                                                         MinHeight="80" MaxHeight="160"
                                                         VerticalScrollBarVisibility="Auto"
                                                         AutomationProperties.AutomationId="PersonaSystemPromptInput"/>
                                                <TextBlock Text="Available variables: {{date}}, {{time}}, {{user_name}} — resolved at message send time"
                                                           FontSize="9" Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,8" TextWrapping="Wrap"/>

                                                <!-- Default Model Config -->
                                                <TextBlock Text="Default Model Configuration" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <ComboBox ItemsSource="{Binding ModelConfigurations}"
                                                          SelectedValue="{Binding EditingPersona.DefaultModelConfigId}"
                                                          SelectedValuePath="Id"
                                                          DisplayMemberPath="DisplayName"
                                                          FontSize="11" Margin="0,0,0,8"
                                                          AutomationProperties.AutomationId="PersonaDefaultModelConfigCombo"/>

                                                <!-- Default Chat Mode -->
                                                <TextBlock Text="Default Chat Mode" FontSize="11"
                                                           Foreground="{DynamicResource SubtleBrush}"
                                                           Margin="0,0,0,3"/>
                                                <ComboBox ItemsSource="{Binding ChatModeOptions}"
                                                          SelectedItem="{Binding EditingPersona.DefaultChatMode}"
                                                          FontSize="11" Margin="0,0,0,8"
                                                          AutomationProperties.AutomationId="PersonaChatModeCombo"/>

                                                <!-- Save / Cancel buttons -->
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource SubtleBrush}"
                                                               VerticalAlignment="Center"/>

                                                    <Button Grid.Column="1" Content="Cancel"
                                                            Margin="0,0,8,0"
                                                            Command="{Binding CancelPersonaEditCommand}"
                                                            Style="{StaticResource SecondaryButtonStyle}"/>

                                                    <Button Grid.Column="2" Content="Save Persona"
                                                            Padding="12,5"
                                                            Command="{Binding SavePersonaCommand}"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            AutomationProperties.AutomationId="SavePersonaButton"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Diagnostics Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Diagnostics">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="🩺 Diagnostics" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Configure diagnostic logging, view log files, and manage log retention. Changes take effect immediately."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <!-- Main content -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <StackPanel>
                            <!-- Log Level Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}"
                                    Margin="0,0,0,12">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Log Level" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Controls the minimum severity level recorded to log files. 'Verbose' captures the most detail."
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <ComboBox ItemsSource="{Binding LogLevelOptions}"
                                              SelectedItem="{Binding LogLevel}"
                                              FontSize="11" Width="200"
                                              HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <!-- Category Toggles Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}"
                                    Margin="0,0,0,12">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Log Categories" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Enable or disable logging for specific subsystems. Disabled categories produce no log output regardless of the global log level."
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <CheckBox IsChecked="{Binding LogCategory_LLMApiCalls}"
                                              Content="LLM API Calls"
                                              FontSize="11"
                                              Foreground="{DynamicResource ContentForeground}"
                                              Margin="0,0,0,4"
                                              ToolTip="Log all LLM provider API requests and responses. Includes provider name, model, token counts, and latency."/>
                                    <CheckBox IsChecked="{Binding LogCategory_Tier1HotkeyPipeline}"
                                              Content="Tier 1 Hotkey Pipeline"
                                              FontSize="11"
                                              Foreground="{DynamicResource ContentForeground}"
                                              Margin="0,0,0,4"
                                              ToolTip="Log global hotkey captures, command routing, and tier 1 overlay lifecycle events."/>
                                    <CheckBox IsChecked="{Binding LogCategory_Tier2CommandBar}"
                                              Content="Tier 2 Command Bar"
                                              FontSize="11"
                                              Foreground="{DynamicResource ContentForeground}"
                                              Margin="0,0,0,4"
                                              ToolTip="Log command bar queries, search execution, and result rendering."/>
                                    <CheckBox IsChecked="{Binding LogCategory_Database}"
                                              Content="Database"
                                              FontSize="11"
                                              Foreground="{DynamicResource ContentForeground}"
                                              Margin="0,0,0,4"
                                              ToolTip="Log EF Core queries, migrations, connection management, and repository operations."/>
                                    <CheckBox IsChecked="{Binding LogCategory_WikiFileSystem}"
                                              Content="Wiki / File System"
                                              FontSize="11"
                                              Foreground="{DynamicResource ContentForeground}"
                                              Margin="0,0,0,4"
                                              ToolTip="Log wiki file indexing, file system watcher events, and wiki service operations."/>
                                    <CheckBox IsChecked="{Binding LogCategory_WebSocket}"
                                              Content="WebSocket"
                                              FontSize="11"
                                              Foreground="{DynamicResource ContentForeground}"
                                              Margin="0,0,0,4"
                                              ToolTip="Log Kestrel WebSocket server connections, messages, and disconnections."/>
                                    <CheckBox IsChecked="{Binding LogCategory_StartupShutdown}"
                                              Content="Startup / Shutdown"
                                              FontSize="11"
                                              Foreground="{DynamicResource ContentForeground}"
                                              Margin="0,0,0,4"
                                              ToolTip="Log application startup, shutdown, service initialization, and DI container events."/>
                                    <CheckBox IsChecked="{Binding LogCategory_SystemIntegration}"
                                              Content="System Integration"
                                              FontSize="11"
                                              Foreground="{DynamicResource ContentForeground}"
                                              Margin="0,0,0,0"
                                              ToolTip="Log system tray, HWND/Dpi capture, clipboard, and low-level Windows integration."/>
                                </StackPanel>
                            </Border>

                            <!-- Log File Management Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Log File Management" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="View, manage, and clear log files stored on disk."
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button Content="📂 Open Logs Folder"
                                                Padding="12,5"
                                                Command="{Binding OpenLogsFolderCommand}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Margin="0,0,8,0"
                                                ToolTip="Open the logs directory in Windows Explorer"/>
                                        <Button Content="🗑️ Clear Logs"
                                                Padding="12,5"
                                                Command="{Binding ClearLogsCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                ToolTip="Delete all .log and .json files in the logs folder"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding StatusMessage}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Appearance Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Appearance">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="🎨 Appearance" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Customize the visual theme, chat layout, and font settings. Changes take effect immediately."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <StackPanel>
                            <!-- Theme Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}"
                                    Margin="0,0,0,12">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Theme" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Switch between Dark and Light mode."
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="🌙 Dark"
                                                     GroupName="AppTheme"
                                                     IsChecked="{Binding AppTheme, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Dark}"
                                                     FontSize="11"
                                                     Foreground="{DynamicResource ContentForeground}"
                                                     Margin="0,0,20,0"/>
                                        <RadioButton Content="☀️ Light"
                                                     GroupName="AppTheme"
                                                     IsChecked="{Binding AppTheme, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Light}"
                                                     FontSize="11"
                                                     Foreground="{DynamicResource ContentForeground}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Chat Theme Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}"
                                    Margin="0,0,0,12">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Chat Theme" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Choose the layout style for chat messages."
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <ComboBox ItemsSource="{Binding ChatThemeOptions}"
                                              SelectedItem="{Binding ChatTheme}"
                                              FontSize="11" Width="200"
                                              HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <!-- Font Settings Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}"
                                    Margin="0,0,0,12">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Font Settings" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Adjust the font family, size, and weight used throughout the application."
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <!-- Font Family -->
                                    <TextBlock Text="Font Family" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding FontFamilyOptions}"
                                              SelectedItem="{Binding FontFamily}"
                                              FontSize="11" Width="220"
                                              HorizontalAlignment="Left" Margin="0,0,0,10"
                                              IsEditable="True"/>

                                    <!-- Font Size Slider -->
                                    <TextBlock Text="Font Size" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               Margin="0,0,0,3"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Slider Minimum="10" Maximum="24" SmallChange="1" LargeChange="2"
                                                Value="{Binding FontSize}" Width="180"
                                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                                        <TextBlock Text="{Binding FontSize, StringFormat={}{0:F0}px}"
                                                   Width="40" TextAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="11" Foreground="{DynamicResource ContentForeground}"/>
                                    </StackPanel>

                                    <!-- Font Weight -->
                                    <TextBlock Text="Font Weight" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding FontWeightOptions}"
                                              SelectedItem="{Binding FontWeight}"
                                              FontSize="11" Width="120"
                                              HorizontalAlignment="Left" Margin="0,0,0,10"/>

                                    <!-- Live Preview -->
                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="4"
                                            Background="{DynamicResource ContentBackground}"
                                            Padding="12,8">
                                        <TextBlock Text="{Binding FontPreviewText}"
                                                   FontFamily="{Binding FontFamily}"
                                                   FontSize="{Binding FontSize}"
                                                   FontWeight="{Binding FontWeight}"
                                                   Foreground="{DynamicResource ContentForeground}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Notifications Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Notifications">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🔔 Notifications" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Configure notification preferences for chat completions, streaming, and cross-tab alerts."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackground}"
                                MaxWidth="500" HorizontalAlignment="Left">
                            <StackPanel Margin="14,12,14,12">
                                <CheckBox IsChecked="{Binding SoundOnCompletion}"
                                          Content="Play Sound on Completion"
                                          FontSize="11"
                                          Foreground="{DynamicResource ContentForeground}"
                                          Margin="0,0,0,8"
                                          ToolTip="Play a notification sound when an AI response finishes generating."/>
                                <CheckBox IsChecked="{Binding DisableStreaming}"
                                          Content="Disable Streaming"
                                          FontSize="11"
                                          Foreground="{DynamicResource ContentForeground}"
                                          Margin="0,0,0,8"
                                          ToolTip="Wait for the entire response before displaying it, instead of showing tokens as they are generated."/>
                                <CheckBox IsChecked="{Binding CrossTabCompletionAlert}"
                                          Content="Cross-Tab Completion Alert"
                                          FontSize="11"
                                          Foreground="{DynamicResource ContentForeground}"
                                          Margin="0,0,0,0"
                                          ToolTip="Show an alert when a chat completes in another tab or window."/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>

                <!-- Startup Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Startup">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🚀 Startup" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Configure application startup behavior, session restore, and system tray preferences."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackground}"
                                MaxWidth="500" HorizontalAlignment="Left">
                            <StackPanel Margin="14,12,14,12">
                                <CheckBox IsChecked="{Binding LaunchOnWindowsStartup}"
                                          Content="Launch on Windows Startup"
                                          FontSize="11"
                                          Foreground="{DynamicResource ContentForeground}"
                                          Margin="0,0,0,8"
                                          ToolTip="Automatically start MySecondBrain when you log into Windows."/>
                                <CheckBox IsChecked="{Binding RestoreLastSession}"
                                          Content="Restore Last Session"
                                          FontSize="11"
                                          Foreground="{DynamicResource ContentForeground}"
                                          Margin="0,0,0,8"
                                          ToolTip="Reopen the last chat threads and tabs when the application starts."/>
                                <CheckBox IsChecked="{Binding MinimizeToTray}"
                                          Content="Minimize to System Tray"
                                          FontSize="11"
                                          Foreground="{DynamicResource ContentForeground}"
                                          Margin="0,0,0,0"
                                          ToolTip="Minimize the application to the system tray instead of the taskbar."/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>

                <!-- Updates Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Updates">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🔄 Updates" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Manage automatic update checking and view your current application version."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <StackPanel>
                            <!-- Check Frequency Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}"
                                    Margin="0,0,0,12">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Check Frequency" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="How often should the application check for updates?"
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <RadioButton Content="Every time the application starts"
                                                 GroupName="UpdateFrequency"
                                                 IsChecked="{Binding UpdateCheckFrequency, Converter={StaticResource EnumMatchConverter}, ConverterParameter=OnStartup}"
                                                 FontSize="11"
                                                 Foreground="{DynamicResource ContentForeground}"
                                                 Margin="0,0,0,6"/>
                                    <RadioButton Content="Daily"
                                                 GroupName="UpdateFrequency"
                                                 IsChecked="{Binding UpdateCheckFrequency, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Daily}"
                                                 FontSize="11"
                                                 Foreground="{DynamicResource ContentForeground}"
                                                 Margin="0,0,0,6"/>
                                    <RadioButton Content="Weekly"
                                                 GroupName="UpdateFrequency"
                                                 IsChecked="{Binding UpdateCheckFrequency, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Weekly}"
                                                 FontSize="11"
                                                 Foreground="{DynamicResource ContentForeground}"
                                                 Margin="0,0,0,6"/>
                                    <RadioButton Content="Manual only (never auto-check)"
                                                 GroupName="UpdateFrequency"
                                                 IsChecked="{Binding UpdateCheckFrequency, Converter={StaticResource EnumMatchConverter}, ConverterParameter=ManualOnly}"
                                                 FontSize="11"
                                                 Foreground="{DynamicResource ContentForeground}"/>
                                </StackPanel>
                            </Border>

                            <!-- Current Version Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Version and Check for Updates" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="View the installed version and manually check for new releases."
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Current Version:" FontSize="11"
                                                   Foreground="{DynamicResource SubtleBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding CurrentVersion}" FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ContentForeground}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                        <Button Content="🔍 Check Now"
                                                Padding="12,5"
                                                Command="{Binding CheckForUpdatesCommand}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Margin="0,0,8,0"
                                                ToolTip="Check for updates now"/>
                                        <TextBlock Text="{Binding UpdateStatusMessage}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource SubtleBrush}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Language Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Language">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🌐 Language" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Configure language detection and RTL text handling."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackground}"
                                MaxWidth="500" HorizontalAlignment="Left">
                            <StackPanel Margin="14,12,14,12">
                                <TextBlock Text="Right-to-Left (RTL) Detection" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ContentForeground}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Automatically detect RTL text (Hebrew Unicode range U+0590–U+05FF) in chat messages and wiki content."
                                           FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <CheckBox IsChecked="{Binding AutoDetectRtl}"
                                          Content="Auto-detect RTL text"
                                          FontSize="11"
                                          Foreground="{DynamicResource ContentForeground}"
                                          ToolTip="When enabled, text in the Hebrew Unicode range (U+0590–U+05FF) is automatically rendered right-to-left."/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>

                <!-- Wiki Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Wiki">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📝 Wiki" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Manage your wiki directory, file indexing, and version control settings."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <StackPanel>
                            <!-- Directory Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}"
                                    Margin="0,0,0,12"
                                    MaxWidth="600" HorizontalAlignment="Left">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Wiki Directory" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Select the folder containing your .md wiki files."
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Path:" FontSize="11"
                                                   Foreground="{DynamicResource SubtleBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding WikiDirectoryPath}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ContentForeground}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap" MaxWidth="350"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button Content="📂 Change"
                                                Padding="12,5"
                                                Command="{Binding ChangeWikiDirectoryCommand}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Margin="0,0,8,0"
                                                ToolTip="Select a new wiki directory"/>
                                        <Button Content="🔄 Re-index Now"
                                                Padding="12,5"
                                                Command="{Binding ReindexWikiCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                ToolTip="Re-scan all .md files in the wiki directory"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding IndexingStatus}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Git Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}"
                                    MaxWidth="600" HorizontalAlignment="Left">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Version Control (Git)" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Track changes to your wiki files using Git version control."
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <CheckBox IsChecked="{Binding GitVersionControlEnabled}"
                                              Content="Initialize git repository"
                                              FontSize="11"
                                              Foreground="{DynamicResource ContentForeground}"
                                              ToolTip="When enabled, a git repository will be initialized in the wiki directory for version tracking."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Backup Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Backup">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="☁️ Backup" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Configure backup provider, schedule, and run manual backups."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackground}"
                                MaxWidth="500" HorizontalAlignment="Left">
                            <StackPanel Margin="14,12,14,12">
                                <TextBlock Text="Backup Provider" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ContentForeground}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding BackupProviderStatus}"
                                           FontSize="11" Foreground="{DynamicResource ContentForeground}"
                                           Margin="0,0,0,10"/>

                                <!-- Schedule -->
                                <TextBlock Text="Backup Schedule" FontSize="11"
                                           Foreground="{DynamicResource SubtleBrush}"
                                           Margin="0,0,0,6"/>
                                <RadioButton Content="Daily"
                                             GroupName="BackupSchedule"
                                             IsChecked="{Binding BackupSchedule, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Daily}"
                                             FontSize="11"
                                             Foreground="{DynamicResource ContentForeground}"
                                             Margin="0,0,0,6"/>
                                <RadioButton Content="Weekly"
                                             GroupName="BackupSchedule"
                                             IsChecked="{Binding BackupSchedule, Converter={StaticResource EnumMatchConverter}, ConverterParameter=Weekly}"
                                             FontSize="11"
                                             Foreground="{DynamicResource ContentForeground}"
                                             Margin="0,0,0,6"/>
                                <RadioButton Content="Manual Only"
                                             GroupName="BackupSchedule"
                                             IsChecked="{Binding BackupSchedule, Converter={StaticResource EnumMatchConverter}, ConverterParameter=ManualOnly}"
                                             FontSize="11"
                                             Foreground="{DynamicResource ContentForeground}"
                                             Margin="0,0,0,10"/>

                                <!-- Last backup -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Last Backup:" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding LastBackupTime}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🔵 Backup Now"
                                            Padding="12,5"
                                            Command="{Binding BackupNowCommand}"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Margin="0,0,8,0"
                                            ToolTip="Start a manual backup now"/>
                                    <Button Content="⚙️ Configure"
                                            Padding="12,5"
                                            Command="{Binding ConfigureBackupCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            ToolTip="Configure backup provider settings"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>

                <!-- Tools Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Tools">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🔧 Tools" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Configure tool auto-approval defaults and speech-to-text settings."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <StackPanel>
                            <!-- Tool Auto-Approval Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}"
                                    Margin="0,0,0,12"
                                    MaxWidth="600" HorizontalAlignment="Left">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Tool Auto-Approval Defaults" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Control whether tools require confirmation before executing. Changes affect newly created chat threads."
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <!-- Web Search -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Web Search" FontSize="11"
                                                   Foreground="{DynamicResource SubtleBrush}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding ToolApprovalOptions}"
                                                  SelectedItem="{Binding WebSearchAutoApproval}"
                                                  FontSize="11" Width="150"
                                                  HorizontalAlignment="Left"/>
                                    </Grid>

                                    <!-- Terminal -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Terminal / Command" FontSize="11"
                                                   Foreground="{DynamicResource SubtleBrush}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding TerminalApprovalOptions}"
                                                  SelectedItem="{Binding TerminalAutoApproval}"
                                                  FontSize="11" Width="150"
                                                  HorizontalAlignment="Left"/>
                                    </Grid>

                                    <!-- File Generate -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="File Generate" FontSize="11"
                                                   Foreground="{DynamicResource SubtleBrush}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding ToolApprovalOptions}"
                                                  SelectedItem="{Binding FileGenerateAutoApproval}"
                                                  FontSize="11" Width="150"
                                                  HorizontalAlignment="Left"/>
                                    </Grid>

                                    <!-- File Edit -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="File Edit" FontSize="11"
                                                   Foreground="{DynamicResource SubtleBrush}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding ToolApprovalOptions}"
                                                  SelectedItem="{Binding FileEditAutoApproval}"
                                                  FontSize="11" Width="150"
                                                  HorizontalAlignment="Left"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Speech-to-Text Section -->
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Background="{DynamicResource CardBackground}"
                                    MaxWidth="600" HorizontalAlignment="Left">
                                <StackPanel Margin="14,12,14,12">
                                    <TextBlock Text="Speech-to-Text (STT)" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Configure the speech recognition provider used for voice input."
                                               FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <TextBlock Text="Provider" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding SttProviderOptions}"
                                              SelectedItem="{Binding SttProvider}"
                                              FontSize="11" Width="200"
                                              HorizontalAlignment="Left" Margin="0,0,0,8"/>

                                    <TextBlock Text="Model" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding SttModel, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="11" Width="200"
                                             HorizontalAlignment="Left" Margin="0,0,0,10"/>

                                    <Button Content="🎤 Test Microphone"
                                            Padding="12,5"
                                            Command="{Binding TestMicrophoneCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            ToolTip="Test your microphone and STT configuration"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Pricing Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Pricing">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="💰 Pricing" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Set monthly budget limits and configure cost alert thresholds."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackground}"
                                MaxWidth="500" HorizontalAlignment="Left">
                            <StackPanel Margin="14,12,14,12">
                                <TextBlock Text="Budget Settings" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ContentForeground}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Set a monthly budget limit and warning threshold to track API usage costs."
                                           FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- Monthly Budget Limit -->
                                <TextBlock Text="Monthly Budget Limit ($)" FontSize="11"
                                           Foreground="{DynamicResource SubtleBrush}"
                                           Margin="0,0,0,3"/>
                                <TextBox Text="{Binding MonthlyBudgetLimit, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="11" Width="150"
                                         HorizontalAlignment="Left" Margin="0,0,0,10"
                                         ToolTip="Leave empty for no limit"/>

                                <!-- Warning Threshold -->
                                <TextBlock Text="Warning Threshold (%)" FontSize="11"
                                           Foreground="{DynamicResource SubtleBrush}"
                                           Margin="0,0,0,3"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Slider Minimum="50" Maximum="100" SmallChange="5" LargeChange="10"
                                            Value="{Binding WarningThreshold}" Width="180"
                                            TickFrequency="5" IsSnapToTickEnabled="True"/>
                                    <TextBlock Text="{Binding WarningThreshold, StringFormat={}{0}%}"
                                               Width="40" TextAlignment="Center" VerticalAlignment="Center"
                                               FontSize="11" Foreground="{DynamicResource ContentForeground}"/>
                                </StackPanel>

                                <!-- Block API on limit -->
                                <CheckBox IsChecked="{Binding BlockApiOnLimit}"
                                          Content="Block API calls when limit reached"
                                          FontSize="11"
                                          Foreground="{DynamicResource ContentForeground}"
                                          ToolTip="When enabled, API calls to paid providers will be blocked once the monthly budget limit is exceeded."/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>

                <!-- Security Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Security">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🔒 Security" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="View encryption status, manage locked chat passwords, and configure visibility settings."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackground}"
                                MaxWidth="500" HorizontalAlignment="Left">
                            <StackPanel Margin="14,12,14,12">
                                <!-- Encryption Status -->
                                <TextBlock Text="Encryption" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ContentForeground}"
                                           Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="✅" FontSize="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding EncryptionStatus}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ContentForeground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Locked Chats -->
                                <TextBlock Text="Locked Chats" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ContentForeground}"
                                           Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding LockedChatPasswordSet, StringFormat='{}🔐 Password set: {0}'}"
                                               FontSize="11"
                                               Foreground="{DynamicResource ContentForeground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="🔑 Set Global Password"
                                            Padding="12,5"
                                            Command="{Binding SetGlobalPasswordCommand}"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Margin="0,0,8,0"
                                            ToolTip="Set or change the global password for locked chats"/>
                                </StackPanel>

                                <CheckBox IsChecked="{Binding HideLockedChats}"
                                          Content="Hide locked chats from chat list"
                                          FontSize="11"
                                          Foreground="{DynamicResource ContentForeground}"
                                          ToolTip="When enabled, locked chats are hidden from the main chat list and must be unlocked to appear."/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>

                <!-- Maintenance Category -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Maintenance">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🛠️ Maintenance" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="16,16,16,4"/>

                    <TextBlock Grid.Row="1" Text="Perform database maintenance tasks such as compaction to reclaim disk space."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap" Margin="16,0,16,12"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  Margin="16,0,16,8">
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackground}"
                                MaxWidth="500" HorizontalAlignment="Left">
                            <StackPanel Margin="14,12,14,12">
                                <TextBlock Text="Database Maintenance" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ContentForeground}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Compact the SQLite database to reclaim space freed by deleted records. The application remains usable during compaction."
                                           FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- Database File Size -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Database Size:" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding DatabaseFileSize}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Reclaimable Space -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Reclaimable:" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding ReclaimableSpace}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Last Compaction -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Last Compaction:" FontSize="11"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding LastCompaction}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ContentForeground}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Compact Button with progress -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                    <Button Padding="12,5"
                                            Command="{Binding CompactDatabaseCommand}"
                                            Margin="0,0,8,0"
                                            ToolTip="Run SQLite VACUUM to reclaim disk space">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                                <Setter Property="Content" Value="🔄 Compact Database"/>
                                                <Setter Property="IsEnabled" Value="True"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompacting}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Content" Value="⏳ Compacting..."/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock Text="{Binding StatusMessage}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SubtleBrush}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>

                <!-- Other categories placeholder -->
                <TextBlock Text="Select a category"
                           Foreground="{DynamicResource SubtleBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Providers">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Profiles">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Diagnostics">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Appearance">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Notifications">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Startup">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Updates">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Language">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Wiki">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Backup">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Tools">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Pricing">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Security">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Maintenance">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>
