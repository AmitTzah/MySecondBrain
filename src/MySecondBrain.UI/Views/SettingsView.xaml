<UserControl x:Class="MySecondBrain.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Column 0: Settings Category Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Settings" FontSize="13" FontWeight="Bold"
                           Foreground="{DynamicResource SidebarForeground}"
                           Margin="12,10,12,6" Padding="0,0,0,6"/>

                <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource SidebarForeground}"
                         FontSize="12">
                    <ListBoxItem Padding="12,7">🔑 Providers</ListBoxItem>
                    <ListBoxItem Padding="12,7">👤 Profiles</ListBoxItem>
                    <ListBoxItem Padding="12,7">🎨 Appearance</ListBoxItem>
                    <ListBoxItem Padding="12,7">📝 Wiki</ListBoxItem>
                    <ListBoxItem Padding="12,7">☁️ Backup</ListBoxItem>
                    <ListBoxItem Padding="12,7">⚡ Text Actions</ListBoxItem>
                    <ListBoxItem Padding="12,7">⌨️ Hotkeys</ListBoxItem>
                    <ListBoxItem Padding="12,7">🔧 Tools</ListBoxItem>
                    <ListBoxItem Padding="12,7">🔔 Notifications</ListBoxItem>
                    <ListBoxItem Padding="12,7">🚀 Startup</ListBoxItem>
                    <ListBoxItem Padding="12,7">🔄 Updates</ListBoxItem>
                    <ListBoxItem Padding="12,7">💰 Pricing</ListBoxItem>
                    <ListBoxItem Padding="12,7">🔒 Security</ListBoxItem>
                    <ListBoxItem Padding="12,7">🛠️ Maintenance</ListBoxItem>
                    <ListBoxItem Padding="12,7">🩺 Diagnostics</ListBoxItem>
                </ListBox>

                <TextBlock Grid.Row="2" Margin="12,8,12,12">
                    <Hyperlink Foreground="{DynamicResource AccentBrush}" FontSize="11"
                               TextDecorations="Underline">
                        🔄 Re-run Onboarding Wizard
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Column 1: Content Area -->
        <Border Grid.Column="1" Background="{DynamicResource ContentBackground}">
            <TextBlock Text="Select a category"
                       Foreground="{DynamicResource SubtleBrush}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
