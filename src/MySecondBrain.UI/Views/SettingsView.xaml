<UserControl x:Class="MySecondBrain.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MySecondBrain.UI.ViewModels"
             xmlns:models="clr-namespace:MySecondBrain.Core.Models;assembly=MySecondBrain.Core"
             xmlns:converters="clr-namespace:MySecondBrain.UI.Converters"
             xmlns:viewsSettings="clr-namespace:MySecondBrain.UI.Views.Settings"
             Background="{DynamicResource ApplicationBackgroundBrush}"
             AutomationProperties.AutomationId="SettingsView">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:EnumMatchConverter x:Key="EnumMatchConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

            <!-- Sidebar item template -->
            <DataTemplate x:Key="SidebarItemTemplate" DataType="vm:SettingsCategoryItem">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Icon}" FontSize="11" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Label}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </DataTemplate>

            <Style x:Key="AccentButtonStyle" TargetType="Button">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Padding" Value="12,5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3" Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Column 0: Settings Category Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Settings" FontSize="13" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="12,10,12,6" Padding="0,0,0,6"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding CategoryItems}"
                         SelectedValue="{Binding SelectedSettingsCategory}" SelectedValuePath="Category"
                         ItemTemplate="{StaticResource SidebarItemTemplate}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontSize="12"/>

                <TextBlock Grid.Row="2" Margin="12,8,12,12"
                           AutomationProperties.AutomationId="ReRunOnboardingLink">
                    <Hyperlink Foreground="{DynamicResource AccentFillColorDefaultBrush}" FontSize="11" TextDecorations="Underline"
                                Command="{Binding ReRunOnboardingCommand}">🔄 Re-run Onboarding Wizard</Hyperlink>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Column 1: Content Area with UserControls -->
        <Border Grid.Column="1" Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <viewsSettings:ProvidersSettingsControl>
                    <viewsSettings:ProvidersSettingsControl.Style>
                        <Style TargetType="viewsSettings:ProvidersSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Providers">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:ProvidersSettingsControl.Style>
                </viewsSettings:ProvidersSettingsControl>

                <viewsSettings:ProfilesSettingsControl>
                    <viewsSettings:ProfilesSettingsControl.Style>
                        <Style TargetType="viewsSettings:ProfilesSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Profiles">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:ProfilesSettingsControl.Style>
                </viewsSettings:ProfilesSettingsControl>

                <viewsSettings:DiagnosticsSettingsControl>
                    <viewsSettings:DiagnosticsSettingsControl.Style>
                        <Style TargetType="viewsSettings:DiagnosticsSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Diagnostics">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:DiagnosticsSettingsControl.Style>
                </viewsSettings:DiagnosticsSettingsControl>

                <viewsSettings:SystemInfoSettingsControl>
                    <viewsSettings:SystemInfoSettingsControl.Style>
                        <Style TargetType="viewsSettings:SystemInfoSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="SystemInfo">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:SystemInfoSettingsControl.Style>
                </viewsSettings:SystemInfoSettingsControl>

                <viewsSettings:AppearanceSettingsControl>
                    <viewsSettings:AppearanceSettingsControl.Style>
                        <Style TargetType="viewsSettings:AppearanceSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Appearance">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:AppearanceSettingsControl.Style>
                </viewsSettings:AppearanceSettingsControl>

                <viewsSettings:NotificationsSettingsControl>
                    <viewsSettings:NotificationsSettingsControl.Style>
                        <Style TargetType="viewsSettings:NotificationsSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Notifications">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:NotificationsSettingsControl.Style>
                </viewsSettings:NotificationsSettingsControl>

                <viewsSettings:StartupSettingsControl>
                    <viewsSettings:StartupSettingsControl.Style>
                        <Style TargetType="viewsSettings:StartupSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Startup">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:StartupSettingsControl.Style>
                </viewsSettings:StartupSettingsControl>

                <viewsSettings:UpdatesSettingsControl>
                    <viewsSettings:UpdatesSettingsControl.Style>
                        <Style TargetType="viewsSettings:UpdatesSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Updates">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:UpdatesSettingsControl.Style>
                </viewsSettings:UpdatesSettingsControl>

                <viewsSettings:LanguageSettingsControl>
                    <viewsSettings:LanguageSettingsControl.Style>
                        <Style TargetType="viewsSettings:LanguageSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Language">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:LanguageSettingsControl.Style>
                </viewsSettings:LanguageSettingsControl>

                <viewsSettings:WikiSettingsControl>
                    <viewsSettings:WikiSettingsControl.Style>
                        <Style TargetType="viewsSettings:WikiSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Wiki">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:WikiSettingsControl.Style>
                </viewsSettings:WikiSettingsControl>

                <viewsSettings:BackupSettingsControl>
                    <viewsSettings:BackupSettingsControl.Style>
                        <Style TargetType="viewsSettings:BackupSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Backup">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:BackupSettingsControl.Style>
                </viewsSettings:BackupSettingsControl>

                <viewsSettings:ToolsSettingsControl>
                    <viewsSettings:ToolsSettingsControl.Style>
                        <Style TargetType="viewsSettings:ToolsSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Tools">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:ToolsSettingsControl.Style>
                </viewsSettings:ToolsSettingsControl>

                <viewsSettings:PricingSettingsControl>
                    <viewsSettings:PricingSettingsControl.Style>
                        <Style TargetType="viewsSettings:PricingSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Pricing">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:PricingSettingsControl.Style>
                </viewsSettings:PricingSettingsControl>

                <viewsSettings:SecuritySettingsControl>
                    <viewsSettings:SecuritySettingsControl.Style>
                        <Style TargetType="viewsSettings:SecuritySettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Security">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:SecuritySettingsControl.Style>
                </viewsSettings:SecuritySettingsControl>

                <viewsSettings:MaintenanceSettingsControl>
                    <viewsSettings:MaintenanceSettingsControl.Style>
                        <Style TargetType="viewsSettings:MaintenanceSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Maintenance">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:MaintenanceSettingsControl.Style>
                </viewsSettings:MaintenanceSettingsControl>

                <viewsSettings:TextActionsSettingsControl>
                    <viewsSettings:TextActionsSettingsControl.Style>
                        <Style TargetType="viewsSettings:TextActionsSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="TextActions">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:TextActionsSettingsControl.Style>
                </viewsSettings:TextActionsSettingsControl>

                <viewsSettings:HotkeysSettingsControl>
                    <viewsSettings:HotkeysSettingsControl.Style>
                        <Style TargetType="viewsSettings:HotkeysSettingsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSettingsCategory}" Value="Hotkeys">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </viewsSettings:HotkeysSettingsControl.Style>
                </viewsSettings:HotkeysSettingsControl>

                <!-- Hotkey recording overlay — shared across all categories -->
                <Border x:Name="RecordingOverlay"
                        Visibility="{Binding IsRecordingHotkey, Converter={StaticResource BoolToVisibility}}"
                        Background="#80000000" Grid.ZIndex="100"
                        IsVisibleChanged="OnRecordingOverlayVisibilityChanged"
                        MouseDown="OnRecordingOverlayMouseDown"
                        KeyDown="OnRecordingKeyDown"
                        Focusable="True">
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="30,20" MaxWidth="400">
                        <StackPanel>
                            <TextBlock Text="Recording Hotkey..." FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="Press a modifier key (Ctrl, Alt, Shift, Win) + a key to set a hotkey. Press Escape to cancel."
                                       FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Border Background="{DynamicResource ApplicationBackgroundBrush}" Padding="12,8"
                                    CornerRadius="4" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <TextBlock Text="{Binding RecordingHotkeyCombo}" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentFillColorDefaultBrush}" TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
