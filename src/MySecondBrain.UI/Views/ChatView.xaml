<UserControl x:Class="MySecondBrain.UI.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Chat Header Bar -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Persona name + context bar -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Default Persona" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource ContentForeground}"
                               VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource InputBackground}"
                            CornerRadius="4" Padding="8,2" Margin="12,0,0,0">
                        <TextBlock Text="Context: 0 / 128K tokens"
                                   FontSize="11" Foreground="{DynamicResource SubtleBrush}"/>
                    </Border>
                    <TextBlock Text="$0.00 total" VerticalAlignment="Center"
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Right: Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="A⁻" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubtleBrush}" FontSize="13"
                            ToolTip="Decrease font size" Padding="4,2"/>
                    <TextBlock Text="{Binding DataContext.FontSizeDisplay, RelativeSource={RelativeSource AncestorType=Window}}"
                                VerticalAlignment="Center"
                                FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                                MinWidth="20" TextAlignment="Center"/>
                    <Button Content="A⁺" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubtleBrush}" FontSize="13"
                            ToolTip="Increase font size" Padding="4,2"/>
                    <Button Command="{Binding DataContext.ToggleThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="{Binding DataContext.ThemeToggleIcon, RelativeSource={RelativeSource AncestorType=Window}}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubtleBrush}" FontSize="14"
                            ToolTip="Toggle dark/light mode" Padding="4,2" Margin="4,0,0,0"/>
                    <Button Content="📌" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubtleBrush}" FontSize="14"
                            ToolTip="Pin chat" Padding="4,2"/>
                    <Button Content="⋯" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubtleBrush}" FontSize="14"
                            ToolTip="More options" Padding="4,2"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Conversation Area -->
        <Border Grid.Row="1" Background="{DynamicResource ContentBackground}">
            <TextBlock Text="No chats yet"
                       Foreground="{DynamicResource SubtleBrush}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Row 2: Input Area -->
        <Border Grid.Row="2" Background="{DynamicResource InputBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="8,4,8,6">
            <StackPanel>
                <!-- Toolbar -->
                <WrapPanel Margin="0,2">
                    <Button Content="🤖 Default Persona ▾" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource ContentForeground}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="🧠 Thinking" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1" Foreground="{DynamicResource AccentBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="🔇 Mute" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="🔧 Tools" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="⚡ Auto-Approve" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="🧠 Memory: On" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1" Foreground="{DynamicResource AccentBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="⚖ Compare" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2"/>
                    <Button Content="📋 Prompts" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="⚡ Actions ▾" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2"/>
                    <Button Content="🎤" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="📷" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="📎 Attach" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2"/>
                    <Button Content="📝 Write to Wiki" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="🔄 Update Memory" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                </WrapPanel>

                <!-- Textbox + Send -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="8,6" Margin="0,0,8,0">
                        <TextBlock Text="Type a message..."
                                   Foreground="{DynamicResource SubtleBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="1" Content="Send"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource AccentForeground}"
                            BorderThickness="0"
                            Padding="16,6" FontSize="13" FontWeight="SemiBold"/>
                </Grid>

                <!-- Token Count -->
                <TextBlock Text="0 chars · ~0 tokens · context at 0%"
                           FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                           Margin="4,2,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
