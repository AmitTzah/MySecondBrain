<UserControl x:Class="MySecondBrain.UI.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MySecondBrain.UI.Views"
             xmlns:controls="clr-namespace:MySecondBrain.UI.Controls"
             xmlns:models="clr-namespace:MySecondBrain.Core.Models;assembly=MySecondBrain.Core"
             xmlns:converters="clr-namespace:MySecondBrain.UI.Converters"
             Background="{DynamicResource ContentBackground}"
             AutomationProperties.AutomationId="ChatView">

    <UserControl.Resources>
        <converters:FlowDirectionConverter x:Key="FlowDirectionConverter"/>
        <converters:RelativeTimeConverter x:Key="RelativeTimeConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:TokenCountToColorConverter x:Key="TokenCountToColorConverter"/>
        <converters:MessageTokenDisplayConverter x:Key="MessageTokenDisplayConverter"/>
        <converters:BoolToFavoriteConverter x:Key="BoolToFavoriteConverter"/>

        <!-- ─── User Message Template ─────────────────────────── -->
        <DataTemplate x:Key="UserMessageTemplate">
            <Border Margin="0,4,0,4" Padding="0">
                <StackPanel FlowDirection="RightToLeft">
                    <!-- Selection checkbox (visible in selection mode) -->
                    <CheckBox Command="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.ToggleMessageSelectionCommand}"
                              CommandParameter="{Binding}"
                              Visibility="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.IsSelectionMode, Converter={StaticResource BoolToVisibilityConverter}}"
                              Margin="4,8,4,0"
                              VerticalAlignment="Top"
                              AutomationProperties.AutomationId="MessageSelectionCheckBox"/>
                    <!-- Role label -->
                    <TextBlock Text="You"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,12,2"/>

                    <!-- Message bubble -->
                    <Border Background="{DynamicResource AccentBrush}"
                            CornerRadius="8,8,2,8"
                            Padding="12,8"
                            MaxWidth="75%"
                            HorizontalAlignment="Right">
                        <FlowDocumentScrollViewer FlowDirection="{Binding Content, Converter={StaticResource FlowDirectionConverter}}"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  MinHeight="20" MaxHeight="400">
                            <FlowDocumentScrollViewer.Style>
                                <Style TargetType="FlowDocumentScrollViewer">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </FlowDocumentScrollViewer.Style>
                            <FlowDocument PagePadding="0"
                                          FontSize="14"
                                          Foreground="{DynamicResource AccentForeground}"/>
                        </FlowDocumentScrollViewer>
                    </Border>

                    <!-- Timestamp + action bar -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,12,0">
                        <TextBlock Text="{Binding CreatedAt, Converter={StaticResource RelativeTimeConverter}}"
                                   FontSize="10" Foreground="{DynamicResource SubtleBrush}"/>
                        <!-- Favorite star -->
                        <Button Content="{Binding IsFavorited, Converter={StaticResource BoolToFavoriteConverter}}"
                                FontSize="12"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource StarBrush}"
                                Padding="2,0" Margin="2,0,0,0"
                                Command="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.ToggleFavoriteCommand}"
                                CommandParameter="{Binding}"
                                ToolTip="Toggle favorite"
                                AutomationProperties.AutomationId="FavoriteBtn"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ─── Assistant Message Template ────────────────────── -->
        <DataTemplate x:Key="AssistantMessageTemplate">
            <Border Margin="0,4,0,4" Padding="0"
                    AutomationProperties.AutomationId="AssistantMessage">
                <StackPanel FlowDirection="LeftToRight">
                    <!-- Role label -->
                    <TextBlock Text="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.ActivePersona.DisplayName, FallbackValue='Assistant'}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource ContentForeground}"
                               Margin="12,0,0,2"/>

                    <!-- Message bubble -->
                    <Border Background="{DynamicResource InputBackground}"
                            CornerRadius="2,8,8,8"
                            Padding="12,8"
                            MaxWidth="75%"
                            HorizontalAlignment="Left"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                        <FlowDocumentScrollViewer FlowDirection="{Binding Content, Converter={StaticResource FlowDirectionConverter}}"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  MinHeight="20" MaxHeight="400">
                            <FlowDocumentScrollViewer.Style>
                                <Style TargetType="FlowDocumentScrollViewer">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </FlowDocumentScrollViewer.Style>
                            <FlowDocument PagePadding="0"
                                          FontSize="14"
                                          Foreground="{DynamicResource ContentForeground}"/>
                        </FlowDocumentScrollViewer>
                    </Border>

                    <!-- Action buttons (Copy MD, Copy Rich, Regenerate, Continue, Favorite) -->
                    <StackPanel Orientation="Horizontal" Margin="12,2,0,0">
                        <!-- Favorite star -->
                        <Button Content="{Binding IsFavorited, Converter={StaticResource BoolToFavoriteConverter}}"
                                FontSize="12"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource StarBrush}"
                                Padding="2,0" Margin="0,0,4,0"
                                Command="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.ToggleFavoriteCommand}"
                                CommandParameter="{Binding}"
                                ToolTip="Toggle favorite"
                                AutomationProperties.AutomationId="FavoriteBtn"/>
                        <TextBlock Text="{Binding CreatedAt, Converter={StaticResource RelativeTimeConverter}}"
                                   FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Content="📋 MD" FontSize="10"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource SubtleBrush}"
                                Padding="4,1" Margin="4,0,0,0"
                                Command="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.CopyMdCommand}"
                                CommandParameter="{Binding}"
                                ToolTip="Copy Markdown"
                                AutomationProperties.AutomationId="CopyMDBtn"/>
                        <Button Content="📄 Rich" FontSize="10"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource SubtleBrush}"
                                Padding="4,1" Margin="2,0,0,0"
                                Command="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.CopyRichCommand}"
                                CommandParameter="{Binding}"
                                ToolTip="Copy formatted (HTML)"
                                AutomationProperties.AutomationId="CopyRichBtn"/>
                        <Button Content="🔄 Regenerate" FontSize="10"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource SubtleBrush}"
                                Padding="4,1" Margin="2,0,0,0"
                                Command="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.RegenerateCommand}"
                                ToolTip="Regenerate this response"
                                AutomationProperties.AutomationId="RegenerateBtn"/>
                        <Button Content="▶ Continue" FontSize="10"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource SubtleBrush}"
                                Padding="4,1" Margin="2,0,0,0"
                                Command="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.ContinueGenerationCommand}"
                                ToolTip="Continue from this response"
                                AutomationProperties.AutomationId="ContinueBtn"/>
                    </StackPanel>

                    <!-- Token usage / cost / generation time footer -->
                    <TextBlock Text="{Binding Converter={StaticResource MessageTokenDisplayConverter}}"
                               FontSize="9" Foreground="{DynamicResource SubtleBrush}"
                               Margin="12,1,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Selection mode checkbox converter -->
        <!-- ─── Bulk Actions Bar Template ─────────────────────── -->
        <DataTemplate x:Key="BulkActionsTemplate">
            <Border Background="{DynamicResource AccentBrush}" Padding="8,6"
                    CornerRadius="4" Margin="8,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.SelectedCount, StringFormat='{}{0} selected'}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentForeground}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <Button Content="Copy" FontSize="11"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource AccentForeground}"
                            Padding="8,3" Margin="2,0"
                            Command="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.CopySelectedMessagesCommand}"
                            AutomationProperties.AutomationId="BulkCopyBtn"/>
                    <Button Content="Delete" FontSize="11"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource AccentForeground}"
                            Padding="8,3" Margin="2,0"
                            Command="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.DeleteSelectedMessagesCommand}"
                            AutomationProperties.AutomationId="BulkDeleteBtn"/>
                    <Button Content="Quote" FontSize="11"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource AccentForeground}"
                            Padding="8,3" Margin="2,0"
                            Command="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.QuoteSelectedMessagesCommand}"
                            AutomationProperties.AutomationId="BulkQuoteBtn"/>
                    <Button Content="Cancel" FontSize="11"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource AccentForeground}"
                            Padding="8,3" Margin="2,0"
                            Command="{Binding Source={RelativeSource AncestorType=UserControl}, Path=DataContext.ToggleSelectionModeCommand}"
                            AutomationProperties.AutomationId="BulkCancelBtn"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ─── System Message Template ───────────────────────── -->
        <DataTemplate x:Key="SystemMessageTemplate">
            <Border Margin="0,4,0,4" Padding="8,4"
                    Background="{DynamicResource InputBackground}"
                    CornerRadius="4">
                <StackPanel FlowDirection="LeftToRight">
                    <TextBlock Text="⚙️ System"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleBrush}"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding Content}"
                               FontSize="12"
                               Foreground="{DynamicResource SubtleBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ─── MessageTemplateSelector ───────────────────────── -->
        <local:MessageDataTemplateSelector x:Key="MessageTemplateSelector"
                                           UserMessageTemplate="{StaticResource UserMessageTemplate}"
                                           AssistantMessageTemplate="{StaticResource AssistantMessageTemplate}"
                                           SystemMessageTemplate="{StaticResource SystemMessageTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Chat Header Bar — standalone ChatHeaderBar control -->
        <local:ChatHeaderBar Grid.Row="0"/>

        <!-- Bulk actions bar (visible in selection mode) -->
        <ContentPresenter Grid.Row="0"
                          Content="{Binding}"
                          ContentTemplate="{StaticResource BulkActionsTemplate}"
                          Visibility="{Binding IsSelectionMode, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Row 1: Offline banner (visible when network unavailable) -->
        <Border Grid.Row="1" Background="#FFF44336" Padding="12,4"
                Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}}"
                AutomationProperties.AutomationId="OfflineBanner">
            <TextBlock Text="You are offline. AI responses are unavailable."
                       FontSize="11" Foreground="White"
                       TextAlignment="Center"/>
        </Border>

        <!-- Row 2: Conversation Area (VirtualizingStackPanel) -->
        <Border Grid.Row="2" Background="{DynamicResource ContentBackground}">
            <Grid>
                <!-- Empty state (visible when no messages) -->
                <StackPanel Visibility="{Binding ActiveTab.Messages.Count, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="No chats yet. Press Ctrl+N to start."
                               FontSize="16" Foreground="{DynamicResource SubtleBrush}"
                               TextAlignment="Center"
                               Visibility="{Binding ActiveTab, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="Start typing below."
                               FontSize="14" Foreground="{DynamicResource SubtleBrush}"
                               TextAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Virtualizing message list -->
                <ScrollViewer x:Name="MessageScrollViewer"
                              Grid.Row="1"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              ScrollChanged="MessageScrollViewer_ScrollChanged">
                    <ListBox ItemsSource="{Binding ActiveTab.Messages}"
                             ItemTemplateSelector="{StaticResource MessageTemplateSelector}"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             BorderThickness="0"
                             Background="Transparent"
                             AutomationProperties.AutomationId="MessageList">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>

                <!-- Error banner (visible when HasError) -->
                <Border x:Name="ErrorBanner"
                        Background="#FFFF5252"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="20,8,20,0"
                        VerticalAlignment="Top"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                        AutomationProperties.AutomationId="ErrorBanner">
                    <StackPanel>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="White"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                        <Button Content="Retry"
                                Foreground="White"
                                Background="Transparent"
                                BorderBrush="White"
                                BorderThickness="1"
                                Padding="12,4"
                                Margin="0,6,0,0"
                                HorizontalAlignment="Left"
                                Command="{Binding RetryCommand}"
                                AutomationProperties.AutomationId="RetryBtn"/>
                    </StackPanel>
                </Border>

                <!-- Auto-scroll paused indicator + Scroll-to-bottom button -->
                <Border x:Name="AutoScrollPausedIndicator"
                        Background="{DynamicResource AccentBrush}"
                        CornerRadius="4"
                        Padding="8,4"
                        Margin="0,0,20,10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Visibility="Collapsed"
                        AutomationProperties.AutomationId="AutoScrollPaused">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Auto-scroll paused"
                                   FontSize="11"
                                   Foreground="{DynamicResource AccentForeground}"
                                   VerticalAlignment="Center"/>
                        <Button Content="\u2193 Scroll to bottom"
                                FontSize="11"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource AccentForeground}"
                                Padding="8,2"
                                Margin="4,0,0,0"
                                Click="ScrollToBottom_Click"
                                AutomationProperties.AutomationId="ScrollToBottomBtn"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Row 3: Input Area -->
        <Border Grid.Row="3" Background="{DynamicResource InputBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="8,4,8,6">
            <StackPanel>
                <!-- Toolbar -->
                <WrapPanel Margin="0,2">
                    <ComboBox ItemsSource="{Binding PersonaList}"
                              SelectedItem="{Binding ActivePersona, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              FontSize="10" Width="160"
                              Background="Transparent"
                              BorderBrush="{DynamicResource BorderBrush}"
                              BorderThickness="1"
                              Foreground="{DynamicResource ContentForeground}"
                              Padding="4,2" Margin="2"
                              VerticalContentAlignment="Center"
                              AutomationProperties.AutomationId="PersonaSelector"/>
                    <!-- Chat Mode Selector -->
                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="4" Margin="2"
                            Padding="0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{Binding ChatModeDisplay}"
                                    FontSize="10"
                                    Padding="6,3"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="{DynamicResource AccentForeground}"
                                    BorderThickness="0"
                                    Command="{Binding SwitchChatModeCommand}"
                                    ToolTip="{Binding ChatModeDisplay, StringFormat='Current: {0}'}"
                                    AutomationProperties.AutomationId="ChatModeBtn"/>
                            <TextBlock Text="{Binding ChatModeDisplay}"
                                       FontSize="9"
                                       Foreground="{DynamicResource SubtleBrush}"
                                       VerticalAlignment="Center"
                                       Margin="4,0,4,0"/>
                        </StackPanel>
                    </Border>

                    <Button Content="🧠 Thinking" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1" Foreground="{DynamicResource AccentBrush}"
                            Padding="6,3" Margin="2"
                            Command="{Binding ToggleThinkingCommand}"
                            AutomationProperties.AutomationId="ThinkingToggleBtn"/>
                    <Button Content="🔇 Mute" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"
                            Command="{Binding ToggleMuteCommand}"
                            AutomationProperties.AutomationId="MuteToggleBtn"/>

                    <ToggleButton x:Name="ToolsDropdownBtn" Content="🔧 Tools ▼" FontSize="10"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Padding="6,3" Margin="2"
                            IsChecked="False"
                            AutomationProperties.AutomationId="ToolsDropdownBtn">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubtleBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=ToolsDropdownBtn}"
                           StaysOpen="False"
                           PlacementTarget="{Binding ElementName=ToolsDropdownBtn}"
                           Placement="Bottom">
                        <Border Background="{DynamicResource ContentBackground}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                MinWidth="160"
                                MaxHeight="300">
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding ToolToggles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding DisplayName}"
                                                      IsChecked="{Binding IsEnabled}"
                                                      Margin="6,3"
                                                      FontSize="11"
                                                      Foreground="{DynamicResource ContentForeground}"
                                                      AutomationProperties.AutomationId="{Binding Name, StringFormat='Tool_{0}'}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Popup>

                    <ToggleButton x:Name="SkillsDropdownBtn" Content="📚 Skills ▼" FontSize="10"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Padding="6,3" Margin="2"
                            IsChecked="False"
                            AutomationProperties.AutomationId="SkillsDropdownBtn">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubtleBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=SkillsDropdownBtn}"
                           StaysOpen="False"
                           PlacementTarget="{Binding ElementName=SkillsDropdownBtn}"
                           Placement="Bottom">
                        <Border Background="{DynamicResource ContentBackground}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                MinWidth="160"
                                MaxHeight="300">
                            <ScrollViewer>
                                <StackPanel>
                                    <Button Content="All On/Off" FontSize="10"
                                            Background="Transparent"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Foreground="{DynamicResource AccentBrush}"
                                            Padding="6,4"
                                            Click="ToggleAllSkills_Click"
                                            AutomationProperties.AutomationId="SkillsAllToggleBtn"/>
                                    <ItemsControl ItemsSource="{Binding SkillToggles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsEnabled}"
                                                          Margin="6,3"
                                                          FontSize="11"
                                                          Foreground="{DynamicResource ContentForeground}"
                                                          AutomationProperties.AutomationId="{Binding Name, StringFormat='Skill_{0}'}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Popup>

                    <ToggleButton x:Name="MemoryToggleBtn" Content="🧠 Mem" FontSize="10"
                            Background="Transparent"
                            BorderThickness="1"
                            Padding="6,3" Margin="2"
                            IsChecked="{Binding MemoryEnabled}"
                            AutomationProperties.AutomationId="MemoryToggleBtn">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubtleBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <Button Content="⚡ Auto-Approve" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="⚖ Compare" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2"/>
                    <Button Content="📋 Prompts" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="⚡ Actions ▾" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2"/>
                    <Button Content="🎤" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="📷" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="📎 Attach" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2"/>
                    <Button Content="📝 Write to Wiki" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="🔄 Update Memory" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                </WrapPanel>

                <!-- Textbox + Send/Stop -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="8,6" Margin="0,0,8,0">
                        <TextBox Text="{Binding ActiveTab.TextboxContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13"
                                 Foreground="{DynamicResource ContentForeground}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="28"
                                 MaxHeight="120"
                                 VerticalScrollBarVisibility="Auto"
                                 AutomationProperties.AutomationId="MessageInput">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Type a message..."
                                                                       Foreground="{DynamicResource SubtleBrush}"
                                                                       FontSize="13"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>
                    <!-- Send / Stop button — transforms based on IsStreaming -->
                    <Button Grid.Column="1" Padding="16,6" FontSize="13" FontWeight="SemiBold"
                            BorderThickness="0"
                            AutomationProperties.AutomationId="SendMessageBtn">
                        <Button.Style>
                            <Style TargetType="Button">
                                <!-- Default: Send -->
                                <Setter Property="Content" Value="Send"/>
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
                                <Setter Property="Command"
                                        Value="{Binding SendMessageCommand}"/>
                                <Style.Triggers>
                                    <!-- Streaming: Stop -->
                                    <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                        <Setter Property="Content" Value="⬛ Stop"/>
                                        <Setter Property="Background" Value="#FF5252"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Command"
                                                Value="{Binding StopGenerationCommand}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Token Count -->
                <TextBlock FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                           Margin="4,2,0,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0:N0} chars · ~{1:N0} tokens · context at {2:P0}">
                            <Binding Path="ActiveTab.TextboxContent.Length"/>
                            <Binding Path="ContextTokens"/>
                            <Binding Path="ContextMaxTokens"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
