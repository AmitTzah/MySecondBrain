<UserControl x:Class="MySecondBrain.UI.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}"
             AutomationProperties.AutomationId="ChatView">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Chat Header Bar -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Persona name + context bar -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding ActivePersona.DisplayName, FallbackValue='Select Persona'}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource ContentForeground}"
                               VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource InputBackground}"
                            CornerRadius="4" Padding="8,2" Margin="12,0,0,0">
                        <TextBlock Text="Context: 0 / 128K tokens"
                                   FontSize="11" Foreground="{DynamicResource SubtleBrush}"/>
                    </Border>
                    <TextBlock Text="$0.00 total" VerticalAlignment="Center"
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Right: Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Chat Theme Selector -->
                    <ComboBox ItemsSource="{Binding DataContext.ChatThemeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.CurrentChatTheme, RelativeSource={RelativeSource AncestorType=Window}}"
                              FontSize="11" Width="90" Margin="0,0,6,0"
                              Background="{DynamicResource InputBackground}"
                              Foreground="{DynamicResource ContentForeground}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              AutomationProperties.AutomationId="ChatThemeCombo">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="A⁻" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubtleBrush}" FontSize="13"
                            ToolTip="Decrease font size" Padding="4,2"
                            Command="{Binding DataContext.DecreaseFontCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            AutomationProperties.AutomationId="DecreaseFontBtn"/>
                    <TextBlock Text="{Binding DataContext.FontSizeDisplay, RelativeSource={RelativeSource AncestorType=Window}}"
                                VerticalAlignment="Center"
                                FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                                MinWidth="20" TextAlignment="Center"
                                AutomationProperties.AutomationId="FontSizeDisplay"/>
                    <Button Content="A⁺" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubtleBrush}" FontSize="13"
                            ToolTip="Increase font size" Padding="4,2"
                            Command="{Binding DataContext.IncreaseFontCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            AutomationProperties.AutomationId="IncreaseFontBtn"/>
                    <Button Command="{Binding DataContext.ToggleThemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Content="{Binding DataContext.ThemeToggleIcon, RelativeSource={RelativeSource AncestorType=Window}}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubtleBrush}" FontSize="14"
                            ToolTip="Toggle dark/light mode" Padding="4,2" Margin="4,0,0,0"
                            AutomationProperties.AutomationId="ThemeToggleBtn"/>
                    <Button Content="📌" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubtleBrush}" FontSize="14"
                            ToolTip="Pin chat" Padding="4,2"/>
                    <Button Content="⋯" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubtleBrush}" FontSize="14"
                            ToolTip="More options" Padding="4,2"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Conversation Area -->
        <Border Grid.Row="1" Background="{DynamicResource ContentBackground}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                <ItemsControl ItemsSource="{Binding SampleMessages, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              ItemTemplate="{Binding DataContext.CurrentMessageTemplate, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </ScrollViewer>
        </Border>

        <!-- Row 2: Input Area -->
        <Border Grid.Row="2" Background="{DynamicResource InputBackground}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="8,4,8,6">
            <StackPanel>
                <!-- Toolbar -->
                <WrapPanel Margin="0,2">
                    <ComboBox ItemsSource="{Binding PersonaList}"
                              SelectedItem="{Binding ActivePersona, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              FontSize="10" Width="160"
                              Background="Transparent"
                              BorderBrush="{DynamicResource BorderBrush}"
                              BorderThickness="1"
                              Foreground="{DynamicResource ContentForeground}"
                              Padding="4,2" Margin="2"
                              VerticalContentAlignment="Center"
                              AutomationProperties.AutomationId="PersonaSelector"/>
                    <Button Content="🧠 Thinking" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1" Foreground="{DynamicResource AccentBrush}"
                            Padding="6,3" Margin="2"
                            AutomationProperties.AutomationId="ThinkingToggleBtn"/>
                    <Button Content="🔇 Mute" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"
                            AutomationProperties.AutomationId="MuteToggleBtn"/>

                    <!-- 🔧 Tools Dropdown -->
                    <ToggleButton x:Name="ToolsDropdownBtn" Content="🔧 Tools ▼" FontSize="10"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Padding="6,3" Margin="2"
                            IsChecked="False"
                            AutomationProperties.AutomationId="ToolsDropdownBtn">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubtleBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=ToolsDropdownBtn}"
                           StaysOpen="False"
                           PlacementTarget="{Binding ElementName=ToolsDropdownBtn}"
                           Placement="Bottom">
                        <Border Background="{DynamicResource ContentBackground}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                MinWidth="160"
                                MaxHeight="300">
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding ToolToggles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding DisplayName}"
                                                      IsChecked="{Binding IsEnabled}"
                                                      Margin="6,3"
                                                      FontSize="11"
                                                      Foreground="{DynamicResource ContentForeground}"
                                                      AutomationProperties.AutomationId="{Binding Name, StringFormat='Tool_{0}'}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Popup>

                    <!-- 📚 Skills Dropdown -->
                    <ToggleButton x:Name="SkillsDropdownBtn" Content="📚 Skills ▼" FontSize="10"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Padding="6,3" Margin="2"
                            IsChecked="False"
                            AutomationProperties.AutomationId="SkillsDropdownBtn">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubtleBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=SkillsDropdownBtn}"
                           StaysOpen="False"
                           PlacementTarget="{Binding ElementName=SkillsDropdownBtn}"
                           Placement="Bottom">
                        <Border Background="{DynamicResource ContentBackground}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                MinWidth="160"
                                MaxHeight="300">
                            <ScrollViewer>
                                <StackPanel>
                                    <!-- All on/off toggle -->
                                    <Button Content="All On/Off" FontSize="10"
                                            Background="Transparent"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Foreground="{DynamicResource AccentBrush}"
                                            Padding="6,4"
                                            Click="ToggleAllSkills_Click"
                                            AutomationProperties.AutomationId="SkillsAllToggleBtn"/>
                                    <ItemsControl ItemsSource="{Binding SkillToggles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsEnabled}"
                                                          Margin="6,3"
                                                          FontSize="11"
                                                          Foreground="{DynamicResource ContentForeground}"
                                                          AutomationProperties.AutomationId="{Binding Name, StringFormat='Skill_{0}'}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Popup>

                    <!-- 🧠 Mem Toggle -->
                    <ToggleButton x:Name="MemoryToggleBtn" Content="🧠 Mem" FontSize="10"
                            Background="Transparent"
                            BorderThickness="1"
                            Padding="6,3" Margin="2"
                            IsChecked="{Binding MemoryEnabled}"
                            AutomationProperties.AutomationId="MemoryToggleBtn">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubtleBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <Button Content="⚡ Auto-Approve" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="⚖ Compare" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2"/>
                    <Button Content="📋 Prompts" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="⚡ Actions ▾" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2"/>
                    <Button Content="🎤" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="📷" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="📎 Attach" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2"/>
                    <Button Content="📝 Write to Wiki" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                    <Button Content="🔄 Update Memory" FontSize="10"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource SubtleBrush}"
                            Padding="6,3" Margin="2"/>
                </WrapPanel>

                <!-- Textbox + Send -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource ContentBackground}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="8,6" Margin="0,0,8,0">
                        <TextBlock Text="Type a message..."
                                   Foreground="{DynamicResource SubtleBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="1" Content="Send"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource AccentForeground}"
                            BorderThickness="0"
                            Padding="16,6" FontSize="13" FontWeight="SemiBold"/>
                </Grid>

                <!-- Token Count -->
                <TextBlock Text="0 chars · ~0 tokens · context at 0%"
                           FontSize="10" Foreground="{DynamicResource SubtleBrush}"
                           Margin="4,2,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
