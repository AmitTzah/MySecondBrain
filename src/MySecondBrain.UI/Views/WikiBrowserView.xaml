<UserControl x:Class="MySecondBrain.UI.Views.WikiBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ApplicationBackgroundBrush}"
             AutomationProperties.AutomationId="WikiBrowserView">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="150"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="280" MinWidth="180"/>
        </Grid.ColumnDefinitions>

        <!-- Column 0: File Tree -->
        <Border Grid.Column="0" Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid AutomationProperties.AutomationId="WikiBrowserView">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📁 Wiki Files"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           FontSize="12" FontWeight="SemiBold"
                           Margin="12,10,12,6"/>

                <!-- Filter input -->
                <Border Grid.Row="1" Margin="8,0,8,6"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="6,4">
                    <TextBlock Text="Filter files..."
                               FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </Border>

                <!-- File list (placeholder) -->
                <Border Grid.Row="2" Margin="12,0,12,12">
                    <TextBlock Text="No .md files found"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Column 1: GridSplitter -->
        <GridSplitter Grid.Column="1" Width="4"
                      Background="{DynamicResource CardStrokeColorDefaultBrush}"
                      ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <!-- Column 2: Markdown Viewer -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Viewer Header -->
            <Border Grid.Row="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Select a file"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="📝 Open in External Editor"
                                Background="Transparent"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                FontSize="11" Padding="8,4" Margin="0,0,6,0"/>
                        <Button Content="💬 Discuss with AI"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                BorderThickness="0"
                                FontSize="11" FontWeight="SemiBold" Padding="8,4"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Viewer Body -->
            <Border Grid.Row="1" Background="{DynamicResource ApplicationBackgroundBrush}">
                <TextBlock Text="Select a file from the tree to view its content."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Column 3: GridSplitter -->
        <GridSplitter Grid.Column="3" Width="4"
                      Background="{DynamicResource CardStrokeColorDefaultBrush}"
                      ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <!-- Column 4: Info Panel -->
        <Border Grid.Column="4" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab headers -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="10,8">
                            <TextBlock Text="Related Sections" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </Border>
                        <Border Padding="10,8">
                            <TextBlock Text="Backlinks" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </Border>
                        <Border Padding="10,8" BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                BorderThickness="0,0,0,2">
                            <TextBlock Text="File Info" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Info Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
                    <StackPanel>
                        <!-- File Info structured rows -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Words" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="—" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                        <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,2"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Characters" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="—" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                        <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,2"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Reading time" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="—" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                        <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,2"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Headings" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="—" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                        <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,2"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Created" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="—" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                        <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,2"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Modified" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="—" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                        <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,2"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cross-links in" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="—" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                        <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,2"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cross-links out" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="—" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Grid>

                        <TextBlock Margin="0,10,0,0">
                            <Hyperlink Foreground="{DynamicResource AccentFillColorDefaultBrush}" FontSize="11"
                                       TextDecorations="Underline">
                                View snapshots →
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
