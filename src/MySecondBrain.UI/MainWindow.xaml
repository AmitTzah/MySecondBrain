<Window x:Class="MySecondBrain.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MySecondBrain.UI.Views"
        xmlns:conv="clr-namespace:MySecondBrain.UI.Converters"
        Title="MySecondBrain" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="800"
        Background="{DynamicResource AppBackground}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:BoolToGridLengthConverter x:Key="BoolToGridLengthConverter"/>

        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavInactiveForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background"
                                        Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="NavBorder" Property="Background"
                                        Value="{DynamicResource NavActiveBackground}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource AccentForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- DataTemplates for screen navigation -->
        <DataTemplate x:Key="ChatsTemplate">
            <views:ChatView/>
        </DataTemplate>
        <DataTemplate x:Key="WikiTemplate">
            <views:WikiBrowserView/>
        </DataTemplate>
        <DataTemplate x:Key="MediaTemplate">
            <views:MediaLibraryView/>
        </DataTemplate>
        <DataTemplate x:Key="ArtifactsTemplate">
            <views:GlobalArtifactsBrowserView/>
        </DataTemplate>
        <DataTemplate x:Key="UsageTemplate">
            <views:UsageDashboardView/>
        </DataTemplate>
        <DataTemplate x:Key="SettingsTemplate">
            <views:SettingsView/>
        </DataTemplate>

        <views:ScreenTemplateSelector x:Key="ScreenSelector"
            ChatsTemplate="{StaticResource ChatsTemplate}"
            WikiTemplate="{StaticResource WikiTemplate}"
            MediaTemplate="{StaticResource MediaTemplate}"
            ArtifactsTemplate="{StaticResource ArtifactsTemplate}"
            UsageTemplate="{StaticResource UsageTemplate}"
            SettingsTemplate="{StaticResource SettingsTemplate}"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="150" MaxWidth="500"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="{Binding IsRightPanelVisible, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=4}"/>
            <ColumnDefinition Width="{Binding IsRightPanelVisible, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=320}"/>
        </Grid.ColumnDefinitions>

        <!-- Column 0: Sidebar -->
        <Grid Grid.Column="0" Background="{DynamicResource SidebarBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- App Navigation -->
            <StackPanel Grid.Row="0" Margin="0,20,0,0">
                <RadioButton Content="💬 Chats"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Chats"
                             Style="{StaticResource NavButtonStyle}"
                             IsChecked="True"/>
                <RadioButton Content="📝 Wiki"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Wiki"
                             Style="{StaticResource NavButtonStyle}"/>
                <RadioButton Content="🖼️ Media"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Media"
                             Style="{StaticResource NavButtonStyle}"/>
                <RadioButton Content="📄 Artifacts"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Artifacts"
                             Style="{StaticResource NavButtonStyle}"/>
                <RadioButton Content="📊 Usage"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Usage"
                             Style="{StaticResource NavButtonStyle}"/>
                <RadioButton Content="⚙️ Settings"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Settings"
                             Style="{StaticResource NavButtonStyle}"/>
            </StackPanel>

            <!-- Chat List Section -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Search Bar -->
                    <Border Margin="8,4" Background="{DynamicResource InputBackground}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="6,4">
                        <TextBlock Text="🔍 Search all chats..."
                                   FontSize="12" Foreground="{DynamicResource SubtleBrush}"/>
                    </Border>

                    <!-- Chats / Timeline Tabs -->
                    <Border Margin="8,4">
                        <StackPanel Orientation="Horizontal">
                            <Border Padding="8,4" BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="0,0,0,2">
                                <TextBlock Text="Chats" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </Border>
                            <Border Padding="8,4">
                                <TextBlock Text="Timeline" FontSize="12"
                                           Foreground="{DynamicResource SubtleBrush}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Chat List -->
                    <StackPanel Margin="8,4">
                        <!-- New Chat Button -->
                        <Button Content="+ New Chat"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="{DynamicResource AccentForeground}"
                                BorderThickness="0"
                                FontSize="12" FontWeight="SemiBold" Padding="12,6"
                                HorizontalAlignment="Stretch" Margin="0,4,0,8"/>

                        <!-- Pinned Section -->
                        <TextBlock Text="📌 PINNED" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource SubtleBrush}"
                                   Margin="4,4,0,4"/>
                        <TextBlock Text="No pinned chats"
                                   FontSize="12" Foreground="{DynamicResource SubtleBrush}"
                                   Margin="8,4"/>

                        <!-- Date: Today -->
                        <TextBlock Text="TODAY" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource SubtleBrush}"
                                   Margin="4,12,0,4"/>
                        <TextBlock Text="No chats yet"
                                   FontSize="12" Foreground="{DynamicResource SubtleBrush}"
                                   Margin="8,4"/>

                        <!-- Reveal Locked Chats -->
                        <TextBlock Margin="0,16,0,0">
                            <Hyperlink Foreground="{DynamicResource SubtleBrush}"
                                       FontSize="11" TextDecorations="Underline">
                                🔒 Reveal Locked Chats
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Column 1: Vertical GridSplitter -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      Background="{DynamicResource GridSplitterBrush}"
                      ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"/>

        <!-- Column 2: Center Content Area -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab Bar (always visible across all screens) -->
            <Border Grid.Row="0" Background="{DynamicResource TabBarBackground}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="4,2">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{DynamicResource TabActiveBackground}"
                            Padding="12,6" Margin="2,0" CornerRadius="4,4,0,0">
                        <TextBlock Text="New Chat" Foreground="{DynamicResource ContentForeground}"
                                   FontSize="12"/>
                    </Border>
                    <Border Background="{DynamicResource TabInactiveBackground}"
                            Padding="12,6" Margin="2,0" CornerRadius="4,4,0,0">
                        <TextBlock Text="Chat 2" Foreground="{DynamicResource SubtleBrush}"
                                   FontSize="12"/>
                    </Border>
                    <Button Content="+" Width="28" Height="28"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubtleBrush}" FontSize="14"
                            VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Screen Content -->
            <ContentControl Grid.Row="1"
                            Content="{Binding SelectedScreen}"
                            ContentTemplateSelector="{StaticResource ScreenSelector}"
                            Background="{DynamicResource ContentBackground}"/>
        </Grid>

        <!-- Column 3: Vertical GridSplitter -->
        <GridSplitter Grid.Column="3"
                      Width="4"
                      Background="{DynamicResource GridSplitterBrush}"
                      ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Visibility="{Binding IsRightPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Column 4: Right Panel -->
        <Grid Grid.Column="4" Background="{DynamicResource PanelBackground}"
              MinWidth="320"
              Visibility="{Binding IsRightPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Artifacts Section -->
            <Grid Grid.Row="0" Margin="12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="📄 Artifacts"
                           Foreground="{DynamicResource PanelForeground}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="No artifacts in this chat yet"
                               Foreground="{DynamicResource SubtleBrush}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <Button Content="💾 Save to Disk"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource PanelForeground}"
                            FontSize="11" Padding="8,4" Margin="0,0,0,4"
                            HorizontalAlignment="Stretch"/>
                    <Button Content="📝 Save to Wiki"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource PanelForeground}"
                            FontSize="11" Padding="8,4"
                            HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Grid>

            <!-- Horizontal GridSplitter -->
            <GridSplitter Grid.Row="1"
                          Height="4"
                          Background="{DynamicResource GridSplitterBrush}"
                          ResizeBehavior="PreviousAndNext"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

            <!-- Row 2: Chat Navigation Section -->
            <Grid Grid.Row="2" Margin="12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="🧭 Chat Navigation"
                           Foreground="{DynamicResource PanelForeground}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <!-- Search in chat -->
                <Border Grid.Row="1" Margin="0,4"
                        Background="{DynamicResource InputBackground}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="6,4">
                    <TextBlock Text="🔍 Search in chat... (Ctrl+F)"
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"/>
                </Border>

                <!-- Favorited only filter -->
                <Button Grid.Row="2" Content="★ Favorited only"
                        Background="Transparent"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Foreground="{DynamicResource PanelForeground}"
                        FontSize="10" Padding="6,3" Margin="0,6,0,8"
                        HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="3"
                           Text="No messages to navigate"
                           Foreground="{DynamicResource SubtleBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
