<UserControl x:Class="MySecondBrain.UI.Controls.TokenContextBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MySecondBrain.UI.Converters"
             Height="6" Width="200"
             AutomationProperties.AutomationId="TokenContextBar">
    <UserControl.Resources>
        <converters:TokenCountToColorConverter x:Key="TokenCountToColorConverter"/>
    </UserControl.Resources>
    <Border x:Name="BackgroundBar" CornerRadius="3"
            Background="{DynamicResource InputBackground}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border x:Name="FillBar" CornerRadius="3"
                HorizontalAlignment="Left"
                Background="{DynamicResource AccentBrush}"/>
    </Border>
</UserControl>
