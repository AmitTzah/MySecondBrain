{
	"mcpServers": {
		"git": {
			"command": "uvx",
			"args": [
				"mcp-server-git",
				"--repository",
				"C:/Users/Amit/Projects/MySecondBrain"
			],
			"alwaysAllow": [
				"git_commit",
				"git_status",
				"git_add",
				"git_diff_unstaged",
				"git_diff_staged",
				"git_log",
				"git_diff",
				"git_create_branch"
			]
		},
		"windows-mcp": {
			"command": "uvx",
			"args": [
				"windows-mcp",
				"serve",
				"--exclude-tools",
				"PowerShell,Registry,Process"
			],
			"env": {
				"ANONYMIZED_TELEMETRY": "false",
				"WINDOWS_MCP_SCREENSHOT_SCALE": "0.5"
			},
			"alwaysAllow": [
				"Snapshot",
				"Screenshot",
				"Wait",
				"WaitFor",
				"Type",
				"Click",
				"App",
				"Scroll",
				"Move",
				"Scrape",
				"Notification",
				"Clipboard",
				"Shortcut"
			]
		}
	}
}